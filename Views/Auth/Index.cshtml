@{
    ViewData["Title"] = "Sign In / Register - Katia Booking";
}

<div class="min-h-screen bg-gradient-to-br from-purple-50 via-pink-50 to-purple-50 flex flex-col">
    <!-- Back Button Header -->
    <div class="p-4">
        <a href="/" class="flex items-center gap-2 text-gray-600 hover:text-gray-900 transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="19 12 5 12"/><polyline points="12 5 5 12 12 19"/></svg>
            <span id="backLabel">Back to Home</span>
        </a>
    </div>

    <!-- Content -->
    <div class="flex-1 flex items-center justify-center p-4">
        <div class="w-full max-w-md">
            <!-- Logo -->
            <div class="text-center mb-8">
                <h1 class="text-4xl font-bold bg-gradient-to-r from-purple-600 to-pink-600 bg-clip-text text-transparent">Katia</h1>
                <p class="text-gray-600 mt-2">Beauty &amp; Wellness Marketplace</p>
            </div>

            <!-- Choice Screen -->
            <div id="screen-choice" class="bg-white rounded-2xl shadow-xl p-8">
                <h2 class="text-2xl font-bold text-center text-gray-900 mb-2">Welcome</h2>
                <p class="text-gray-600 text-center mb-8">How would you like to continue?</p>

                <div class="space-y-4">
                    <!-- Client Option -->
                    <button onclick="showMode('client')" class="w-full p-6 rounded-xl border-2 border-gray-200 hover:border-purple-400 hover:bg-purple-50 transition-all group text-left">
                        <div class="flex items-center gap-4">
                            <div class="w-14 h-14 rounded-full bg-gradient-to-r from-purple-500 to-pink-500 flex items-center justify-center flex-shrink-0">
                                <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                            </div>
                            <div>
                                <h3 class="font-bold text-gray-900 text-lg">I'm a Client</h3>
                                <p class="text-sm text-gray-600">Book appointments at beauty salons</p>
                            </div>
                        </div>
                    </button>

                    <!-- Salon Option -->
                    <button onclick="showMode('salon')" class="w-full p-6 rounded-xl border-2 border-purple-200 bg-gradient-to-br from-purple-50 to-pink-50 hover:border-purple-400 transition-all group text-left">
                        <div class="flex items-center gap-4">
                            <div class="w-14 h-14 rounded-full bg-gradient-to-r from-blue-500 to-cyan-500 flex items-center justify-center flex-shrink-0">
                                <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>
                            </div>
                            <div>
                                <h3 class="font-bold text-gray-900 text-lg">I'm a Business Owner</h3>
                                <p class="text-sm text-gray-600">Manage my salon and accept bookings</p>
                            </div>
                        </div>
                    </button>
                </div>
            </div>

            <!-- Client Form -->
            <div id="screen-client" class="hidden bg-white rounded-2xl shadow-xl overflow-hidden">
                <div class="flex border-b border-gray-200">
                    <button onclick="setTab('signin')" id="tab-signin-client" class="flex-1 py-4 text-center font-semibold transition-colors text-purple-600 border-b-2 border-purple-600 bg-purple-50">
                        Sign In
                    </button>
                    <button onclick="setTab('signup')" id="tab-signup-client" class="flex-1 py-4 text-center font-semibold transition-colors text-gray-500 hover:text-gray-700">
                        Sign Up
                    </button>
                </div>

                <div class="p-8">
                    <!-- Sign In Form -->
                    <div id="form-signin-client">
                        <h3 class="text-xl font-bold text-gray-900 mb-6">Welcome back</h3>
                        <form onsubmit="handleClientSignIn(event)" class="space-y-4">
                            <div>
                                <label for="client-email" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                                <input id="client-email" type="email" placeholder="you@example.com" required class="w-full h-11 px-4 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-purple-400 text-sm" />
                            </div>
                            <div>
                                <label for="client-password" class="block text-sm font-medium text-gray-700 mb-1">Password</label>
                                <input id="client-password" type="password" placeholder="••••••••" required class="w-full h-11 px-4 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-purple-400 text-sm" />
                            </div>
                            <div class="flex items-center justify-between">
                                <label class="flex items-center gap-2 text-sm text-gray-600">
                                    <input type="checkbox" class="rounded border-gray-300" />
                                    Remember me
                                </label>
                                <a href="#" class="text-sm text-purple-600 hover:text-purple-700">Forgot password?</a>
                            </div>
                            <button type="submit" class="w-full h-12 bg-gradient-to-r from-purple-600 to-pink-600 hover:from-purple-700 hover:to-pink-700 text-white rounded-lg font-medium transition-all">
                                Sign In
                            </button>
                        </form>
                        <div class="mt-6">
                            <div class="relative">
                                <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-gray-200"></div></div>
                                <div class="relative flex justify-center text-xs uppercase"><span class="bg-white px-2 text-gray-500">Or continue with</span></div>
                            </div>
                            <div class="mt-4 grid grid-cols-2 gap-3">
                                <button class="flex items-center justify-center gap-2 h-11 border border-gray-200 rounded-lg hover:bg-gray-50 text-sm font-medium text-gray-700 transition-colors">
                                    <svg class="w-5 h-5" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
                                    Google
                                </button>
                                <button class="flex items-center justify-center gap-2 h-11 bg-black rounded-lg hover:bg-gray-900 text-sm font-medium text-white transition-colors">
                                    <svg class="w-5 h-5 fill-white" viewBox="0 0 24 24"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
                                    Apple
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Sign Up Form -->
                    <div id="form-signup-client" class="hidden">
                        <h3 class="text-xl font-bold text-gray-900 mb-6">Create your account</h3>
                        <form onsubmit="handleClientSignUp(event)" class="space-y-4">
                            <div>
                                <label for="client-name" class="block text-sm font-medium text-gray-700 mb-1">Full Name</label>
                                <input id="client-name" type="text" placeholder="John Doe" required class="w-full h-11 px-4 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-purple-400 text-sm" />
                            </div>
                            <div>
                                <label for="client-reg-email" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                                <input id="client-reg-email" type="email" placeholder="you@example.com" required class="w-full h-11 px-4 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-purple-400 text-sm" />
                            </div>
                            <div>
                                <label for="client-reg-password" class="block text-sm font-medium text-gray-700 mb-1">Password</label>
                                <input id="client-reg-password" type="password" placeholder="Min. 8 characters" required minlength="8" class="w-full h-11 px-4 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-purple-400 text-sm" />
                            </div>
                            <div>
                                <label for="client-reg-phone" class="block text-sm font-medium text-gray-700 mb-1">Phone (optional)</label>
                                <input id="client-reg-phone" type="tel" placeholder="+971 50 000 0000" class="w-full h-11 px-4 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-purple-400 text-sm" />
                            </div>
                            <button type="submit" class="w-full h-12 bg-gradient-to-r from-purple-600 to-pink-600 hover:from-purple-700 hover:to-pink-700 text-white rounded-lg font-medium transition-all">
                                Create Account
                            </button>
                        </form>
                    </div>
                </div>

                <div class="px-8 pb-8 text-center">
                    <p class="text-sm text-gray-600">Are you a business owner?
                        <button onclick="showMode('salon')" class="text-purple-600 hover:text-purple-700 font-semibold">Register your salon &rarr;</button>
                    </p>
                </div>
            </div>

            <!-- Salon Form -->
            <div id="screen-salon" class="hidden bg-white rounded-2xl shadow-xl overflow-hidden">
                <div class="flex border-b border-gray-200">
                    <button onclick="setSalonTab('signin')" id="tab-signin-salon" class="flex-1 py-4 text-center font-semibold transition-colors text-purple-600 border-b-2 border-purple-600 bg-purple-50">
                        Sign In
                    </button>
                    <button onclick="setSalonTab('signup')" id="tab-signup-salon" class="flex-1 py-4 text-center font-semibold transition-colors text-gray-500 hover:text-gray-700">
                        Sign Up
                    </button>
                </div>

                <div class="p-8">
                    <!-- Salon Sign In -->
                    <div id="form-signin-salon">
                        <h3 class="text-xl font-bold text-gray-900 mb-2">Salon Login</h3>
                        <p class="text-sm text-gray-600 mb-6">Access your salon dashboard</p>
                        <form onsubmit="handleSalonSignIn(event)" class="space-y-4">
                            <div>
                                <label for="salon-email" class="block text-sm font-medium text-gray-700 mb-1">Business Email</label>
                                <input id="salon-email" type="email" placeholder="salon@example.com" required class="w-full h-11 px-4 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-purple-400 text-sm" />
                            </div>
                            <div>
                                <label for="salon-password" class="block text-sm font-medium text-gray-700 mb-1">Password</label>
                                <input id="salon-password" type="password" placeholder="••••••••" required class="w-full h-11 px-4 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-purple-400 text-sm" />
                            </div>
                            <button type="submit" class="w-full h-12 bg-gradient-to-r from-blue-600 to-cyan-600 hover:from-blue-700 hover:to-cyan-700 text-white rounded-lg font-medium transition-all">
                                Sign In to Dashboard
                            </button>
                        </form>
                    </div>

                    <!-- Salon Sign Up -->
                    <div id="form-signup-salon" class="hidden">
                        <h3 class="text-xl font-bold text-gray-900 mb-2">Register Your Salon</h3>
                        <p class="text-sm text-gray-600 mb-6">Join Katia and grow your business</p>
                        <form onsubmit="handleSalonSignUp(event)" class="space-y-4">
                            <div>
                                <label for="salon-name" class="block text-sm font-medium text-gray-700 mb-1">Salon Name</label>
                                <input id="salon-name" type="text" placeholder="e.g. Bella Beauty" required class="w-full h-11 px-4 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-purple-400 text-sm" />
                            </div>
                            <div>
                                <label for="salon-reg-email" class="block text-sm font-medium text-gray-700 mb-1">Business Email</label>
                                <input id="salon-reg-email" type="email" placeholder="salon@example.com" required class="w-full h-11 px-4 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-purple-400 text-sm" />
                            </div>
                            <div>
                                <label for="salon-reg-phone" class="block text-sm font-medium text-gray-700 mb-1">Phone Number</label>
                                <input id="salon-reg-phone" type="tel" placeholder="+971 50 000 0000" required class="w-full h-11 px-4 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-purple-400 text-sm" />
                            </div>
                            <div>
                                <label for="salon-reg-password" class="block text-sm font-medium text-gray-700 mb-1">Password</label>
                                <input id="salon-reg-password" type="password" placeholder="Min. 8 characters" required minlength="8" class="w-full h-11 px-4 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-purple-400 text-sm" />
                            </div>
                            <button type="submit" class="w-full h-12 bg-gradient-to-r from-blue-600 to-cyan-600 hover:from-blue-700 hover:to-cyan-700 text-white rounded-lg font-medium transition-all">
                                Register Salon
                            </button>
                        </form>
                    </div>
                </div>

                <div class="px-8 pb-8 text-center">
                    <p class="text-sm text-gray-600">Looking to book an appointment?
                        <button onclick="showMode('client')" class="text-purple-600 hover:text-purple-700 font-semibold">Sign in as client &rarr;</button>
                    </p>
                </div>
            </div>

            <!-- Legal Footer -->
            <p class="text-xs text-gray-500 text-center mt-6">
                By continuing, you agree to our
                <a href="/terms" class="text-purple-600 hover:underline">Terms of Service</a>
                and
                <a href="/privacy" class="text-purple-600 hover:underline">Privacy Policy</a>
            </p>
        </div>
    </div>
</div>

<script src="https://cdn.tailwindcss.com"></script>

<script>
    let currentMode = 'choice';
    let currentTab = 'signin';
    let currentSalonTab = 'signin';

    // Check URL param on load
    (function() {
        const params = new URLSearchParams(window.location.search);
        const type = params.get('type');
        if (type === 'client') showMode('client');
        else if (type === 'salon') showMode('salon');
    })();

    function showMode(mode) {
        currentMode = mode;
        document.getElementById('screen-choice').classList.add('hidden');
        document.getElementById('screen-client').classList.add('hidden');
        document.getElementById('screen-salon').classList.add('hidden');

        if (mode === 'choice') {
            document.getElementById('screen-choice').classList.remove('hidden');
            document.getElementById('backLabel').textContent = 'Back to Home';
        } else if (mode === 'client') {
            document.getElementById('screen-client').classList.remove('hidden');
            document.getElementById('backLabel').textContent = 'Back';
        } else if (mode === 'salon') {
            document.getElementById('screen-salon').classList.remove('hidden');
            document.getElementById('backLabel').textContent = 'Back';
        }
    }

    document.querySelector('a[href="/"]').addEventListener('click', function(e) {
        if (currentMode !== 'choice') {
            e.preventDefault();
            showMode('choice');
        }
    });

    function setTab(tab) {
        currentTab = tab;
        const signin = document.getElementById('form-signin-client');
        const signup = document.getElementById('form-signup-client');
        const tabSignin = document.getElementById('tab-signin-client');
        const tabSignup = document.getElementById('tab-signup-client');

        if (tab === 'signin') {
            signin.classList.remove('hidden');
            signup.classList.add('hidden');
            tabSignin.className = 'flex-1 py-4 text-center font-semibold transition-colors text-purple-600 border-b-2 border-purple-600 bg-purple-50';
            tabSignup.className = 'flex-1 py-4 text-center font-semibold transition-colors text-gray-500 hover:text-gray-700';
        } else {
            signin.classList.add('hidden');
            signup.classList.remove('hidden');
            tabSignup.className = 'flex-1 py-4 text-center font-semibold transition-colors text-purple-600 border-b-2 border-purple-600 bg-purple-50';
            tabSignin.className = 'flex-1 py-4 text-center font-semibold transition-colors text-gray-500 hover:text-gray-700';
        }
    }

    function setSalonTab(tab) {
        currentSalonTab = tab;
        const signin = document.getElementById('form-signin-salon');
        const signup = document.getElementById('form-signup-salon');
        const tabSignin = document.getElementById('tab-signin-salon');
        const tabSignup = document.getElementById('tab-signup-salon');

        if (tab === 'signin') {
            signin.classList.remove('hidden');
            signup.classList.add('hidden');
            tabSignin.className = 'flex-1 py-4 text-center font-semibold transition-colors text-purple-600 border-b-2 border-purple-600 bg-purple-50';
            tabSignup.className = 'flex-1 py-4 text-center font-semibold transition-colors text-gray-500 hover:text-gray-700';
        } else {
            signin.classList.add('hidden');
            signup.classList.remove('hidden');
            tabSignup.className = 'flex-1 py-4 text-center font-semibold transition-colors text-purple-600 border-b-2 border-purple-600 bg-purple-50';
            tabSignin.className = 'flex-1 py-4 text-center font-semibold transition-colors text-gray-500 hover:text-gray-700';
        }
    }

    function handleClientSignIn(e) { e.preventDefault(); window.location.href = '/Dashboard'; }
    function handleClientSignUp(e) { e.preventDefault(); window.location.href = '/Dashboard'; }
    function handleSalonSignIn(e) { e.preventDefault(); window.location.href = '/Dashboard'; }
    function handleSalonSignUp(e) { e.preventDefault(); window.location.href = '/Admin/BecomePartner'; }
</script>
