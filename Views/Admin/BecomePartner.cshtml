@{
    Layout = null;
    ViewData["Title"] = "Become a Partner";
    ViewData["Description"] = "Join Katia and get your AI Receptionist for your beauty salon. Never miss a client again.";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Katia Beauty Platform</title>
    <meta name="description" content="@ViewData["Description"]" />
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .carousel-container { overflow: hidden; width: 100%; }
        .carousel-track {
            display: flex;
            gap: 3rem;
            animation: scroll 20s linear infinite;
            width: max-content;
        }
        .carousel-item {
            font-weight: 700;
            font-size: 0.85rem;
            letter-spacing: 0.1em;
            color: #9ca3af;
            white-space: nowrap;
            padding: 0 1rem;
        }
        @@keyframes scroll {
            0% { transform: translateX(0); }
            100% { transform: translateX(-50%); }
        }
    </style>
</head>
<body class="min-h-screen bg-white">

    <!-- Header -->
    <header class="bg-white/80 backdrop-blur-md border-b border-purple-100 sticky top-0 z-50">
        <div class="container mx-auto px-4 py-4 flex items-center justify-between max-w-7xl">
            <a href="/" class="flex items-center gap-2">
                <div class="w-8 h-8 bg-gradient-to-r from-purple-600 to-pink-600 rounded-lg flex items-center justify-center">
                    <span class="text-white font-bold text-sm">K</span>
                </div>
                <span class="font-bold text-xl bg-gradient-to-r from-purple-600 to-pink-600 bg-clip-text text-transparent">Katia</span>
            </a>
            <nav class="hidden md:flex items-center gap-6">
                <a href="/" class="text-gray-600 hover:text-purple-600 transition-colors text-sm font-medium">Home</a>
                <a href="/pricing" class="text-gray-600 hover:text-purple-600 transition-colors text-sm font-medium">Pricing</a>
                <a href="/contact" class="text-gray-600 hover:text-purple-600 transition-colors text-sm font-medium">Contact</a>
                <a href="/auth" class="bg-gradient-to-r from-purple-600 to-pink-600 text-white px-4 py-2 rounded-lg text-sm font-medium hover:opacity-90 transition-opacity">Sign In</a>
            </nav>
        </div>
    </header>

    <!-- Hero Section -->
    <div class="bg-gradient-to-b from-purple-50 to-white py-16 md:py-20">
        <div class="container mx-auto px-4">

            <!-- Back Button -->
            <a href="javascript:history.back()" class="flex items-center gap-2 text-gray-600 hover:text-gray-900 mb-8 transition-colors group w-fit">
                <svg class="w-5 h-5 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
                </svg>
                <span class="font-medium">Back</span>
            </a>

            <div class="grid lg:grid-cols-2 gap-12 items-center max-w-7xl mx-auto">

                <!-- Left Side -->
                <div>
                    <div class="inline-flex items-center gap-2 px-4 py-2 bg-purple-100 rounded-full mb-6">
                        <svg class="w-4 h-4 text-purple-600" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                        </svg>
                        <span class="text-sm text-purple-600 font-medium">The Future of Salon Management</span>
                    </div>

                    <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6">
                        <span class="text-gray-900">Your Salon Needs an </span>
                        <span class="bg-gradient-to-r from-purple-600 to-pink-600 bg-clip-text text-transparent">AI Receptionist</span>
                    </h1>

                    <p class="text-lg text-gray-600 mb-8">
                        Stop losing clients to missed calls. Katia AI answers instantly, consults clients, and books appointments directly into your calendar. 24/7.
                    </p>

                    <div class="grid sm:grid-cols-2 gap-6">
                        <div class="flex gap-4">
                            <div class="w-12 h-12 rounded-xl bg-purple-100 flex items-center justify-center flex-shrink-0">
                                <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                                </svg>
                            </div>
                            <div>
                                <h3 class="font-bold text-gray-900 mb-1">AI Receptionist 24/7</h3>
                                <p class="text-sm text-gray-600">Never miss a client. Our AI answers calls and messages instantly, booking appointments day and night.</p>
                            </div>
                        </div>

                        <div class="flex gap-4">
                            <div class="w-12 h-12 rounded-xl bg-blue-100 flex items-center justify-center flex-shrink-0">
                                <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/>
                                </svg>
                            </div>
                            <div>
                                <h3 class="font-bold text-gray-900 mb-1">Real-time Voice Booking</h3>
                                <p class="text-sm text-gray-600">Clients can talk naturally to our AI, and it will find the perfect slot in your calendar automatically.</p>
                            </div>
                        </div>

                        <div class="flex gap-4">
                            <div class="w-12 h-12 rounded-xl bg-green-100 flex items-center justify-center flex-shrink-0">
                                <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
                                </svg>
                            </div>
                            <div>
                                <h3 class="font-bold text-gray-900 mb-1">Business Growth</h3>
                                <p class="text-sm text-gray-600">Access powerful analytics and marketing tools to scale your revenue.</p>
                            </div>
                        </div>

                        <div class="flex gap-4">
                            <div class="w-12 h-12 rounded-xl bg-red-100 flex items-center justify-center flex-shrink-0">
                                <svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                                </svg>
                            </div>
                            <div>
                                <h3 class="font-bold text-gray-900 mb-1">No Hidden Fees</h3>
                                <p class="text-sm text-gray-600">One monthly price for your whole team. No per user commissions or charges.</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Right Side - Form -->
                <div>
                    <div class="border-2 border-gray-200 shadow-2xl rounded-xl bg-white">
                        <div class="p-8">
                            <h2 class="text-2xl font-bold text-gray-900 mb-2">Get Your AI Assistant</h2>
                            <p class="text-sm text-gray-600 mb-6">Enter your details to start automating your salon</p>

                            <div id="partner-success" class="hidden mb-4 p-4 bg-green-50 border border-green-200 rounded-lg text-green-700 text-sm font-medium">
                                Thank you! We'll be in touch shortly. Redirecting to pricing...
                            </div>
                            <div id="partner-error" class="hidden mb-4 p-4 bg-red-50 border border-red-200 rounded-lg text-red-700 text-sm font-medium"></div>

                            <form id="partner-form" class="space-y-4">
                                <div>
                                    <label class="text-sm font-medium text-gray-700 mb-2 block">Salon Name</label>
                                    <input type="text" id="salonName" placeholder="e.g. Bella Beauty" required
                                        class="w-full h-12 px-3 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent" />
                                </div>

                                <div>
                                    <label class="text-sm font-medium text-gray-700 mb-2 block">Phone</label>
                                    <div class="flex gap-2">
                                        <select id="countryCode"
                                            class="w-32 h-12 px-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-purple-500">
                                            <option value="+971">🇦🇪 +971</option>
                                            <option value="+44">🇬🇧 +44</option>
                                            <option value="+1">🇺🇸 +1</option>
                                            <option value="+33">🇫🇷 +33</option>
                                            <option value="+49">🇩🇪 +49</option>
                                            <option value="+39">🇮🇹 +39</option>
                                            <option value="+34">🇪🇸 +34</option>
                                            <option value="+7">🇷🇺 +7</option>
                                            <option value="+91">🇮🇳 +91</option>
                                            <option value="+966">🇸🇦 +966</option>
                                            <option value="+20">🇪🇬 +20</option>
                                            <option value="+90">🇹🇷 +90</option>
                                            <option value="+55">🇧🇷 +55</option>
                                            <option value="+81">🇯🇵 +81</option>
                                        </select>
                                        <input type="tel" id="phone" placeholder="50 123 4567" required
                                            class="flex-1 h-12 px-3 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent" />
                                    </div>
                                </div>

                                <div>
                                    <label class="text-sm font-medium text-gray-700 mb-2 block">Email Address</label>
                                    <input type="email" id="partnerEmail" placeholder="you@example.com" required
                                        class="w-full h-12 px-3 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent" />
                                </div>

                                <button type="submit" id="partner-submit"
                                    class="w-full h-12 bg-gradient-to-r from-purple-600 to-pink-600 hover:from-purple-700 hover:to-pink-700 text-white font-medium rounded-lg transition-all disabled:opacity-60">
                                    Get Your AI Assistant
                                </button>

                                <p class="text-xs text-center text-gray-500">No credit card required to view our plans</p>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Trusted By -->
    <div class="py-12 border-y border-gray-200 bg-gray-50">
        <div class="container mx-auto px-4">
            <p class="text-center text-sm text-gray-500 mb-6 uppercase tracking-widest">
                Trusted by top salons in Dubai, London, and New York
            </p>
            <div class="carousel-container">
                <div class="carousel-track">
                    <div class="carousel-item">HARPER'S BAZAAR</div>
                    <div class="carousel-item">COSMOPOLITAN</div>
                    <div class="carousel-item">VANITY FAIR</div>
                    <div class="carousel-item">MARIE CLAIRE</div>
                    <div class="carousel-item">VOGUE</div>
                    <div class="carousel-item">ELLE</div>
                    <div class="carousel-item">GLAMOUR</div>
                    <div class="carousel-item">HARPER'S BAZAAR</div>
                    <div class="carousel-item">HARPER'S BAZAAR</div>
                    <div class="carousel-item">COSMOPOLITAN</div>
                    <div class="carousel-item">VANITY FAIR</div>
                    <div class="carousel-item">MARIE CLAIRE</div>
                    <div class="carousel-item">VOGUE</div>
                    <div class="carousel-item">ELLE</div>
                    <div class="carousel-item">GLAMOUR</div>
                    <div class="carousel-item">HARPER'S BAZAAR</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer class="bg-gray-900 text-gray-400 py-12">
        <div class="container mx-auto px-4 max-w-6xl">
            <div class="flex flex-col md:flex-row items-center justify-between gap-4">
                <div class="flex items-center gap-2">
                    <div class="w-8 h-8 bg-gradient-to-r from-purple-600 to-pink-600 rounded-lg flex items-center justify-center">
                        <span class="text-white font-bold text-sm">K</span>
                    </div>
                    <span class="text-white font-bold text-lg">Katia</span>
                </div>
                <p class="text-sm">&copy; 2024 Katia Beauty Platform. All rights reserved.</p>
                <div class="flex gap-4 text-sm">
                    <a href="/pricing" class="hover:text-white transition-colors">Pricing</a>
                    <a href="/contact" class="hover:text-white transition-colors">Contact</a>
                </div>
            </div>
        </div>
    </footer>

<script>
document.getElementById('partner-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    const btn = document.getElementById('partner-submit');
    const successEl = document.getElementById('partner-success');
    const errorEl = document.getElementById('partner-error');

    btn.disabled = true;
    btn.textContent = 'Submitting...';
    successEl.classList.add('hidden');
    errorEl.classList.add('hidden');

    try {
        const resp = await fetch('/leads', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                businessName: document.getElementById('salonName').value,
                ownerName: document.getElementById('salonName').value,
                phone: document.getElementById('countryCode').value + document.getElementById('phone').value,
                email: document.getElementById('partnerEmail').value,
                city: 'Dubai',
                planInterest: 'Basic'
            })
        });

        if (resp.ok) {
            successEl.classList.remove('hidden');
            setTimeout(() => { window.location.href = '/pricing'; }, 2000);
        } else {
            errorEl.textContent = 'Something went wrong. Please try again.';
            errorEl.classList.remove('hidden');
        }
    } catch {
        errorEl.textContent = 'Failed to submit. Please try again.';
        errorEl.classList.remove('hidden');
    } finally {
        btn.disabled = false;
        btn.textContent = 'Get Your AI Assistant';
    }
});
</script>
</body>
</html>


