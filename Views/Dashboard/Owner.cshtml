<script>
const tabTitles = {
    'overview': { title: 'Dashboard', subtitle: 'Welcome back!' },
    'my-salons': { title: 'My Salons', subtitle: 'Manage multiple salon locations' },
    'calendar': { title: 'Calendar', subtitle: 'Manage your booking calendar' },
    'clients': { title: 'Clients', subtitle: 'Client database and history' },
    'masters': { title: 'Masters & Targets', subtitle: 'Performance tracking and targets' },
    'services': { title: 'Services', subtitle: 'Manage salon services' },
    'package-deals': { title: 'Package Deals', subtitle: 'Create bundled service packages' },
    'dynamic-pricing': { title: 'Dynamic Pricing', subtitle: 'Real-time price adjustments' },
    'gift-cards': { title: 'Gift Cards', subtitle: 'Manage gift card programs' },
    'referral-program': { title: 'Referral Program', subtitle: 'Client referral rewards' },
    'ai-smart-filling': { title: 'AI Smart Filling', subtitle: 'AI-powered appointment management' },
    'advanced-forecasting': { title: 'Advanced Forecasting', subtitle: 'Predictive business analytics' },
    'booking-settings': { title: 'Booking Settings', subtitle: 'Configure booking preferences' },
    'products': { title: 'Products', subtitle: 'Product catalog management' },
    'inventory': { title: 'Inventory', subtitle: 'Manage product stock levels' },
    'attendance': { title: 'Attendance', subtitle: 'Track staff attendance' },
    'reviews': { title: 'Reviews', subtitle: 'Manage client feedback' },
    'staff': { title: 'Staff Management', subtitle: 'Manage team members' },
    'expense': { title: 'Expenses', subtitle: 'Financial tracking and costs' },
    'loyalty': { title: 'Loyalty Program', subtitle: 'Manage client rewards' },
    'advanced-analytics': { title: 'Advanced Analytics', subtitle: 'Detailed business insights' },
    'feed-analytics': { title: 'Feed Analytics', subtitle: 'Social feed performance' },
    'waiting-list': { title: 'Waiting List', subtitle: 'Manage appointment queue' },
    'notifications': { title: 'Notifications', subtitle: 'Alert preferences and history' },
    'media': { title: 'Photos & Gallery', subtitle: 'Media management' },
    'marketing': { title: 'Marketing', subtitle: 'Promotional campaigns' },
    'ai-tools': { title: 'AI Tools', subtitle: 'Configure AI features' },
    'export': { title: 'Export Data', subtitle: 'Download and backup data' },
    'settings': { title: 'Settings', subtitle: 'Salon configuration' }
};

function switchTab(tabName) {
    document.querySelectorAll('.panel').forEach(el => el.classList.remove('active'));
    document.querySelectorAll('.nav-link').forEach(el => {
        el.classList.remove('active');
        el.classList.add('text-gray-700', 'hover:bg-purple-50', 'hover:text-purple-600');
    });
    
    const panel = document.getElementById('panel-' + tabName);
    const navLink = document.querySelector(`[data-tab="${tabName}"]`);
    
    if (panel) panel.classList.add('active');
    if (navLink) {
        navLink.classList.add('active');
        navLink.classList.remove('text-gray-700', 'hover:bg-purple-50', 'hover:text-purple-600');
    }
    
const titleInfo = tabTitles[tabName] || { title: 'Dashboard', subtitle: '' };
document.getElementById('page-title').textContent = titleInfo.title;
document.getElementById('page-subtitle').textContent = titleInfo.subtitle;

if (tabName === 'my-salons' && currentUser) loadMySalons();
else if (tabName === 'clients' && salonId) loadClientsList();
else if (tabName === 'staff' && salonId) loadStaff();
else if (tabName === 'masters' && salonId) loadMasters();
else if (tabName === 'services' && salonId) loadServices();
else if (tabName === 'calendar' && salonId) loadCalendar();
else if (tabName === 'products' && salonId) loadProducts();
else if (tabName === 'inventory' && salonId) loadInventory();
else if (tabName === 'reviews' && salonId) loadReviews();
else if (tabName === 'notifications' && salonId) loadNotifications();
else if (tabName === 'attendance' && salonId) loadAttendance();
else if (tabName === 'settings' && salonId) loadSettings();
}

async function init() {
    const token = localStorage.getItem('auth_token');
    if (!token) { window.location.href = '/auth'; return; }

    try {
        const resp = await fetch('/auth/me', { headers: { 'Authorization': 'Bearer ' + token } });
        if (!resp.ok) { window.location.href = '/auth'; return; }
        const user = await resp.json();
        currentUser = user;

        document.getElementById('user-name-display').textContent = user.fullName || user.email || '';
        document.getElementById('user-initials').textContent = (user.fullName || user.email || '??').split(' ').map(n => n[0]).join('').toUpperCase().substring(0, 2);

        const salonResp = await fetch('/salons/user/' + user.id, { headers: { 'Authorization': 'Bearer ' + token } });
        if (salonResp.ok) {
            const salonData = await salonResp.json();
            const salons = salonData.salons || salonData || [];
            if (salons && salons.length > 0) {
                // Check for stored salon preference
                const storedSalonId = localStorage.getItem('selected_salon_id');
                let salon = salons[0];
                
                if (storedSalonId) {
                    const foundSalon = salons.find(s => s.id === storedSalonId || s.id === storedSalonId.replace(/['"]/g, ''));
                    if (foundSalon) {
                        salon = foundSalon;
                    }
                }
                
                salonId = salon.id;
                document.getElementById('salon-name-sidebar').textContent = salon.name;
                loadDashboardData();
            } else {
                document.getElementById('salon-name-sidebar').textContent = 'No salon found';
            }
        }
    } catch (e) {
        console.error(e);
    }
}

async function loadDashboardData() {
    const token = localStorage.getItem('auth_token') || '';
    
    try {
        const resp = await fetch('/bookings/salon/' + salonId, { headers: { 'Authorization': 'Bearer ' + token } });
        if (resp.ok) {
            const data = await resp.json();
            const bookings = data.bookings || [];
            updateOverviewStats(bookings);
        }
    } catch (e) {}
}

function updateOverviewStats(bookings) {
    const today = new Date().toDateString();
    const todayBookings = bookings.filter(b => new Date(b.startTime).toDateString() === today);
    
    const statTodayEl = document.querySelector('#panel-overview [data-stat="today"]');
    if (statTodayEl) statTodayEl.textContent = todayBookings.length;
    
    fetch('/clients/salon/' + salonId, { headers: { 'Authorization': 'Bearer ' + localStorage.getItem('auth_token') } })
        .then(r => r.json())
        .then(data => {
            const clientsEl = document.querySelector('#panel-overview [data-stat="clients"]');
            if (clientsEl) clientsEl.textContent = data.totalCount || (data.clients || []).length || 0;
        });
}

function signOut() {
    localStorage.removeItem('auth_token');
    localStorage.removeItem('user_data');
    window.location.href = '/';
}

init();
</script>
