    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Katia</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .nav-link { transition: all 0.2s; }
        .nav-link:hover { transform: translateX(4px); }
        .nav-link.active { background: linear-gradient(to right, #9333ea, #ec4899); color: white; }
        .sidebar-scroll::-webkit-scrollbar { width: 6px; }
        .sidebar-scroll::-webkit-scrollbar-track { background: #f1f1f1; }
        .sidebar-scroll::-webkit-scrollbar-thumb { background: #d1d5db; border-radius: 3px; }
        .sidebar-scroll::-webkit-scrollbar-thumb:hover { background: #9ca3af; }
        .panel { display: none; }
        .panel.active { display: block; }
</style>
</head>
<body class="min-h-screen bg-gray-50">
<script>
    let salonId = null;
    let currentUser = null;
</script>

