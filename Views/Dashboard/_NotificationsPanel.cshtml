        <button onclick="markAllRead()" class="px-4 py-2 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50">Mark All Read</button>
    </div>

    <!-- Unread Count -->
    <div class="bg-gradient-to-r from-purple-600 to-pink-600 rounded-xl p-6 text-white">
