            <div>
                <h3 class="text-2xl font-bold">3 Unread Notifications</h3>
                <p class="opacity-90">You have new notifications to review</p>
            </div>
            <button onclick="switchTab('notifications')" class="px-6 py-2 bg-white text-purple-600 rounded-lg font-medium hover:bg-purple-50">
