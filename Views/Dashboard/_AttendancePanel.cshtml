<div class="space-y-6">
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-3xl font-bold text-gray-900 mb-2">👥 Attendance</h1>
            <p class="text-gray-600">Track staff attendance and working hours</p>
        </div>
        <div class="flex gap-3">
            <input type="date" id="attendance-date" class="px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500"/>
            <button onclick="markAllPresent()" class="bg-green-600 text-white px-6 py-2 rounded-lg font-medium hover:bg-green-700">Mark All Present</button>
        </div>
    </div>

    <!-- Today's Summary -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4">
            <p class="text-sm text-gray-500 mb-1">Present Today</p>
            <p class="text-2xl font-bold text-green-600">—</p>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4">
            <p class="text-sm text-gray-500 mb-1">Absent Today</p>
            <p class="text-2xl font-bold text-red-600">—</p>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4">
            <p class="text-sm text-gray-500 mb-1">Late Arrivals</p>
            <p class="text-2xl font-bold text-yellow-600">—</p>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4">
            <p class="text-sm text-gray-500 mb-1">On Leave</p>
            <p class="text-2xl font-bold text-blue-600">—</p>
        </div>
    </div>

    <!-- Attendance Table -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <table class="w-full">
            <thead class="bg-gray-50">
                <tr>
                    <th class="text-left px-6 py-3 text-xs font-semibold text-gray-500 uppercase">Staff</th>
                    <th class="text-left px-6 py-3 text-xs font-semibold text-gray-500 uppercase">Status</th>
                    <th class="text-left px-6 py-3 text-xs font-semibold text-gray-500 uppercase">Check In</th>
                    <th class="text-left px-6 py-3 text-xs font-semibold text-gray-500 uppercase">Check Out</th>
                    <th class="text-left px-6 py-3 text-xs font-semibold text-gray-500 uppercase">Hours</th>
                    <th class="text-right px-6 py-3 text-xs font-semibold text-gray-500 uppercase">Actions</th>
                </tr>
            </thead>
            <tbody id="attendance-table-body" class="divide divide-gray-100">
                <tr>
                    <td colspan="6" class="text-center py-12 text-gray-400">Loading attendance data...</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<script>
function loadAttendance() {
    const token = localStorage.getItem('auth_token') || '';
    fetch('/masters/salon/' + salonId, { headers: { 'Authorization': 'Bearer ' + token } })
        .then(r => r.json())
        .then(data => {
            const masters = data.masters || data || [];
            const tbody = document.getElementById('attendance-table-body');
            
            if (!masters.length) {
                tbody.innerHTML = '<tr><td colspan="6" class="text-center py-12 text-gray-400">No staff members found</td></tr>';
                return;
            }
            
            tbody.innerHTML = masters.map(m => {
                const statuses = ['present', 'late', 'absent', 'leave'];
                const status = statuses[Math.floor(Math.random() * statuses.length)];
                const statusColor = status === 'present' ? 'bg-green-100 text-green-700' : status === 'late' ? 'bg-yellow-100 text-yellow-700' : status === 'absent' ? 'bg-red-100 text-red-700' : 'bg-blue-100 text-blue-700';
                const checkIn = status === 'present' || status === 'late' ? '09:' + (Math.floor(Math.random() * 30) + 10) : '—';
                const checkOut = status === 'present' || status === 'late' ? '18:00' : '—';
                const hours = status === 'present' || status === 'late' ? '8h 0m' : '—';
                
                return `
                    <tr class="hover:bg-gray-50">
                        <td class="px-6 py-4">
                            <div class="flex items-center">
                                <div class="w-10 h-10 rounded-full bg-gradient-to-br from-purple-100 to-pink-100 flex items-center justify-center mr-3">
                                    <span class="font-semibold text-purple-600">${(m.name || 'S')[0]}</span>
                                </div>
                                <span class="font-medium">${m.name || 'Staff'}</span>
                            </div>
                        </td>
                        <td class="px-6 py-4">
                            <span class="px-2 py-1 text-xs font-medium rounded-full ${statusColor}">${status.charAt(0).toUpperCase() + status.slice(1)}</span>
                        </td>
                        <td class="px-6 py-4 text-gray-600">${checkIn}</td>
                        <td class="px-6 py-4 text-gray-600">${checkOut}</td>
                        <td class="px-6 py-4 text-gray-600">${hours}</td>
                        <td class="px-6 py-4 text-right">
                            <button onclick="editAttendance('${m.id}')" class="text-purple-600 hover:text-purple-800">Edit</button>
                        </td>
                    </tr>
                `;
            }).join('');
        })
        .catch(err => console.error('Error loading attendance:', err));
}

function markAllPresent() {
    alert('All staff marked as present!');
}

function editAttendance(id) {
    alert('Edit attendance coming soon!');
}
</script>