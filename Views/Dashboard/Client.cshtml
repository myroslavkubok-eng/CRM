@{
    Layout = null;
    ViewData["Title"] = "Client Dashboard";
    ViewData["Description"] = "Your bookings, gift cards, and favourite salons.";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Katia</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen bg-gradient-to-br from-purple-50 via-pink-50 to-purple-50">

    <!-- Header -->
    <header class="bg-white/80 backdrop-blur-md border-b border-purple-100 sticky top-0 z-50">
        <div class="container mx-auto px-4 py-4 flex items-center justify-between max-w-6xl">
            <a href="/" class="flex items-center gap-2">
                <div class="w-8 h-8 bg-gradient-to-r from-purple-600 to-pink-600 rounded-lg flex items-center justify-center">
                    <span class="text-white font-bold text-sm">K</span>
                </div>
                <span class="font-bold text-xl bg-gradient-to-r from-purple-600 to-pink-600 bg-clip-text text-transparent">Katia</span>
            </a>
            <div class="flex items-center gap-3">
                <span id="user-name" class="text-sm font-medium text-gray-700 hidden md:block"></span>
                <div class="w-9 h-9 bg-gradient-to-r from-purple-600 to-pink-600 rounded-full flex items-center justify-center">
                    <span id="user-initial" class="text-white font-bold text-sm">?</span>
                </div>
                <button onclick="signOut()" class="text-sm text-gray-500 hover:text-red-500">Sign Out</button>
            </div>
        </div>
    </header>

    <div class="container mx-auto px-4 py-8 max-w-5xl">

        <!-- Welcome Header -->
        <div class="mb-8">
            <h1 class="text-3xl font-bold text-gray-900 mb-1">Welcome back, <span id="welcome-name">there</span>!</h1>
            <p class="text-gray-600">Your beauty journey at a glance</p>
        </div>

        <!-- Tab Navigation -->
        <div class="flex gap-1 bg-white rounded-xl p-1 shadow-sm border border-gray-100 mb-6 w-fit">
            <button onclick="showTab('bookings')" id="tab-bookings" class="tab-btn px-5 py-2.5 rounded-lg text-sm font-semibold bg-gradient-to-r from-purple-600 to-pink-600 text-white">
                My Bookings
            </button>
            <button onclick="showTab('salons')" id="tab-salons" class="tab-btn px-5 py-2.5 rounded-lg text-sm font-semibold text-gray-600 hover:text-purple-600 transition-colors">
                Find Salons
            </button>
            <button onclick="showTab('giftcards')" id="tab-giftcards" class="tab-btn px-5 py-2.5 rounded-lg text-sm font-semibold text-gray-600 hover:text-purple-600 transition-colors">
                Gift Cards
            </button>
        </div>

        <!-- Bookings Tab -->
        <div id="panel-bookings">
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-lg font-bold text-gray-900">My Appointments</h2>
                <a href="/salon/listing" class="bg-gradient-to-r from-purple-600 to-pink-600 text-white px-4 py-2 rounded-lg text-sm font-medium hover:opacity-90">
                    + Book New
                </a>
            </div>

            <div id="bookings-loading" class="text-center py-12 text-gray-400">Loading your bookings...</div>
            <div id="bookings-empty" class="hidden text-center py-16">
                <div class="w-20 h-20 bg-gradient-to-r from-purple-100 to-pink-100 rounded-full flex items-center justify-center mx-auto mb-4">
                    <svg class="w-10 h-10 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                </div>
                <h3 class="text-xl font-semibold text-gray-900 mb-2">No bookings yet</h3>
                <p class="text-gray-600 mb-6">Book your first appointment at one of our amazing salons!</p>
                <a href="/salon/listing" class="bg-gradient-to-r from-purple-600 to-pink-600 text-white px-6 py-3 rounded-xl font-medium hover:opacity-90 transition-opacity">
                    Browse Salons
                </a>
            </div>
            <div id="bookings-list" class="hidden space-y-4"></div>
        </div>

        <!-- Salons Tab -->
        <div id="panel-salons" class="hidden text-center py-16">
            <h2 class="text-xl font-bold text-gray-900 mb-4">Discover Beauty Salons</h2>
            <a href="/salon/listing" class="bg-gradient-to-r from-purple-600 to-pink-600 text-white px-8 py-3 rounded-xl font-medium hover:opacity-90 transition-opacity inline-block">
                Browse Salons Near You
            </a>
        </div>

        <!-- Gift Cards Tab -->
        <div id="panel-giftcards" class="hidden">
            <h2 class="text-lg font-bold text-gray-900 mb-4">My Gift Cards</h2>
            <div id="giftcards-list" class="text-center py-12 text-gray-400">Loading gift cards...</div>
        </div>
    </div>

<script>
async function init() {
    const token = localStorage.getItem('auth_token');
    if (!token) { window.location.href = '/auth'; return; }

    try {
        const resp = await fetch('/auth/me', { headers: { 'Authorization': 'Bearer ' + token } });
        if (!resp.ok) { window.location.href = '/auth'; return; }
        const user = await resp.json();

        const name = user.fullName || user.email || 'there';
        document.getElementById('user-name').textContent = name;
        document.getElementById('user-initial').textContent = name[0].toUpperCase();
        document.getElementById('welcome-name').textContent = name.split(' ')[0];

        loadBookings(user.id, token);
        loadGiftCards(user.id, token);
    } catch { window.location.href = '/auth'; }
}

async function loadBookings(userId, token) {
    try {
        const resp = await fetch('/bookings?clientId=' + userId, { headers: { 'Authorization': 'Bearer ' + token } });
        document.getElementById('bookings-loading').classList.add('hidden');
        if (resp.ok) {
            const data = await resp.json();
            const bookings = data.bookings || data || [];
            if (!bookings.length) {
                document.getElementById('bookings-empty').classList.remove('hidden');
                return;
            }
            document.getElementById('bookings-list').classList.remove('hidden');
            document.getElementById('bookings-list').innerHTML = bookings.map(b => `
                <div class="bg-white rounded-xl p-5 shadow-sm border border-gray-100">
                    <div class="flex items-start justify-between">
                        <div>
                            <h3 class="font-bold text-gray-900">${b.serviceName || 'Appointment'}</h3>
                            <p class="text-sm text-gray-600 mt-0.5">${b.salonName || '—'}</p>
                            <p class="text-sm text-gray-500 mt-1">${b.startTime ? new Date(b.startTime).toLocaleString() : '—'}</p>
                        </div>
                        <span class="px-3 py-1 rounded-full text-xs font-semibold ${statusClass(b.status)}">${b.status || 'pending'}</span>
                    </div>
                    ${b.status === 'pending' || b.status === 'confirmed' ? `
                    <div class="mt-4 flex gap-2">
                        <a href="/salon/booking/${b.salonId}" class="text-sm text-purple-600 hover:underline font-medium">Reschedule</a>
                    </div>` : ''}
                </div>
            `).join('');
        } else {
            document.getElementById('bookings-empty').classList.remove('hidden');
        }
    } catch { document.getElementById('bookings-loading').classList.add('hidden'); document.getElementById('bookings-empty').classList.remove('hidden'); }
}

async function loadGiftCards(userId, token) {
    try {
        const resp = await fetch('/gift-cards?clientId=' + userId, { headers: { 'Authorization': 'Bearer ' + token } });
        if (resp.ok) {
            const data = await resp.json();
            const cards = data.giftCards || data || [];
            document.getElementById('giftcards-list').innerHTML = cards.length
                ? cards.map(c => `<div class="bg-white rounded-xl p-5 shadow-sm border border-purple-100 mb-3">
                    <div class="flex justify-between items-center">
                        <p class="font-bold text-purple-600 text-lg">AED ${c.balance || c.amount || 0}</p>
                        <span class="text-xs text-gray-500">Code: ${c.code || '—'}</span>
                    </div>
                    <p class="text-sm text-gray-500 mt-1">Expires: ${c.expiresAt ? new Date(c.expiresAt).toLocaleDateString() : 'N/A'}</p>
                </div>`).join('')
                : '<p class="text-gray-400 text-sm py-8 text-center">No gift cards found.</p>';
        }
    } catch {}
}

function statusClass(status) {
    const map = { confirmed: 'bg-green-100 text-green-700', pending: 'bg-yellow-100 text-yellow-700', cancelled: 'bg-red-100 text-red-700', completed: 'bg-blue-100 text-blue-700' };
    return map[status] || 'bg-gray-100 text-gray-700';
}

function showTab(name) {
    ['bookings','salons','giftcards'].forEach(t => {
        document.getElementById('panel-' + t).classList.toggle('hidden', t !== name);
        const btn = document.getElementById('tab-' + t);
        if (t === name) {
            btn.className = 'tab-btn px-5 py-2.5 rounded-lg text-sm font-semibold bg-gradient-to-r from-purple-600 to-pink-600 text-white';
        } else {
            btn.className = 'tab-btn px-5 py-2.5 rounded-lg text-sm font-semibold text-gray-600 hover:text-purple-600 transition-colors';
        }
    });
}

function signOut() {
    localStorage.removeItem('auth_token');
    localStorage.removeItem('user_data');
    window.location.href = '/';
}

init();
</script>
</body>
</html>


