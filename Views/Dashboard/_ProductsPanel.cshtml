<div class="space-y-6">
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-3xl font-bold text-gray-900 mb-2">Products</h1>
            <p class="text-gray-600">Manage product catalog</p>
        </div>
        <button onclick="openAddProductModal()" class="bg-gradient-to-r from-purple-600 to-pink-600 text-white px-6 py-2.5 rounded-lg font-medium hover:opacity-90">
            + Add Product
        </button>
    </div>

    <!-- Filters -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4">
        <div class="flex flex-col md:flex-row gap-4">
            <div class="flex-1">
                <input type="text" id="product-search" placeholder="Search products..." class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500"/>
            </div>
            <select id="product-category" class="px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500">
                <option value="">All Categories</option>
                <option value="hair">Hair Care</option>
                <option value="skin">Skin Care</option>
                <option value="nails">Nail Care</option>
                <option value="makeup">Makeup</option>
                <option value="tools">Tools & Accessories</option>
            </select>
        </div>
    </div>

    <!-- Products Grid -->
    <div id="products-grid" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
        <div class="text-center py-12 col-span-full text-gray-400">Loading products...</div>
    </div>
</div>

<script>
function loadProducts() {
    const token = localStorage.getItem('auth_token') || '';
    fetch('/products/salon/' + salonId, { headers: { 'Authorization': 'Bearer ' + token } })
        .then(r => r.json())
        .then(data => {
            const products = data.products || data || [];
            const grid = document.getElementById('products-grid');
            
            if (!products.length) {
                grid.innerHTML = `
                    <div class="text-center col-span-full py-12">
                        <svg class="w-20 h-20 mx-auto mb-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
                        <p class="text-gray-500 mb-4">No products yet</p>
                        <button onclick="openAddProductModal()" class="px-6 py-2 bg-purple-100 text-purple-700 rounded-lg font-medium hover:bg-purple-200">Add First Product</button>
                    </div>
                `;
                return;
            }
            
            grid.innerHTML = products.map(p => `
                <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-lg transition-shadow">
                    <div class="h-48 bg-gray-100 flex items-center justify-center">
                        ${p.image ? `<img src="${p.image}" class="w-full h-full object-cover"/>` : '<svg class="w-16 h-16 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>'}
                    </div>
                    <div class="p-4">
                        <h3 class="font-bold text-gray-900 mb-1">${p.name || 'Product'}</h3>
                        <p class="text-sm text-gray-600 mb-2">${p.category || 'General'}</p>
                        <div class="flex items-center justify-between">
                            <span class="font-bold text-purple-600">$${p.price || 0}</span>
                            <span class="text-xs text-gray-500">${p.stock || 0} in stock</span>
                        </div>
                    </div>
                </div>
            `).join('');
        })
        .catch(err => {
            console.error('Error loading products:', err);
            document.getElementById('products-grid').innerHTML = '<div class="text-center col-span-full text-red-500">Error loading products</div>';
        });
}

function openAddProductModal() {
    alert('Add product feature coming soon!');
}
</script>