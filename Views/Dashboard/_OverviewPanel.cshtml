<div class="space-y-6">
    <div>
        <h1 class="text-3xl font-bold text-gray-900 mb-2">Dashboard</h1>
        <p class="text-gray-600">Welcome back! Here's what's happening today.</p>
    </div>

    <!-- Stats Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
            <div class="flex items-center justify-between mb-4">
                <svg class="w-10 h-10 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
                <div class="text-right">
                    <div class="text-2xl font-bold text-gray-900" data-stat="today">—</div>
                    <div class="text-xs text-gray-500">Today's Bookings</div>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
            <div class="flex items-center justify-between mb-4">
                <svg class="w-10 h-10 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <div class="text-right">
                    <div class="text-2xl font-bold text-gray-900">$—</div>
                    <div class="text-xs text-gray-500">This Week Revenue</div>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
            <div class="flex items-center justify-between mb-4">
                <svg class="w-10 h-10 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
                </svg>
                <div class="text-right">
                    <div class="text-2xl font-bold text-gray-900" data-stat="clients">—</div>
                    <div class="text-xs text-gray-500">Total Clients</div>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
            <div class="flex items-center justify-between mb-4">
                <svg class="w-10 h-10 text-yellow-600 fill-current" viewBox="0 0 24 24">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
                <div class="text-right">
                    <div class="text-2xl font-bold text-gray-900">—</div>
                    <div class="text-xs text-gray-500">Rating</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Access Grid -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <div class="mb-6">
            <h3 class="text-lg font-bold text-gray-900">Quick Access</h3>
            <p class="text-sm text-gray-500">Navigate to key features</p>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
            <!-- Calendar -->
            <button onclick="switchTab('calendar')" class="rounded-xl p-6 text-left transition-all border bg-white hover:shadow-lg border-gray-100">
                <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-3 bg-blue-100">
                    <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                </div>
                <h3 class="font-bold mb-1 text-gray-900">Calendar</h3>
                <p class="text-sm text-gray-500">Manage bookings</p>
            </button>

            <!-- Masters -->
            <button onclick="switchTab('masters')" class="rounded-xl p-6 text-left transition-all border bg-white hover:shadow-lg border-gray-100">
                <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-3 bg-green-100">
                    <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
                </div>
                <h3 class="font-bold mb-1 text-gray-900">Masters</h3>
                <p class="text-sm text-gray-500">Manage staff</p>
            </button>

            <!-- Clients -->
            <button onclick="switchTab('clients')" class="rounded-xl p-6 text-left transition-all border bg-white hover:shadow-lg border-gray-100">
                <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-3 bg-pink-100">
                    <svg class="w-6 h-6 text-pink-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
                </div>
                <h3 class="font-bold mb-1 text-gray-900">Client Database</h3>
                <p class="text-sm text-gray-500">History & Favorites</p>
            </button>

            <!-- Services -->
            <button onclick="switchTab('services')" class="rounded-xl p-6 text-left transition-all border bg-white hover:shadow-lg border-gray-100">
                <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-3 bg-purple-100">
                    <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.121 14.121L19 19m-7-7l7-7m-7 7l-2.879 2.879M12 12L9.121 9.121m0 5.758a3 3 0 10-4.243 4.243 3 3 0 004.243-4.243z"/></svg>
                </div>
                <h3 class="font-bold mb-1 text-gray-900">Services</h3>
                <p class="text-sm text-gray-500">Manage services</p>
            </button>

            <!-- Package Deals -->
            <button onclick="switchTab('package-deals')" class="rounded-xl p-6 text-left transition-all border bg-white hover:shadow-lg border-gray-100">
                <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-3 bg-indigo-100">
                    <svg class="w-6 h-6 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                </div>
                <h3 class="font-bold mb-1 text-gray-900">Package Deals</h3>
                <p class="text-sm text-gray-500">Create bundles</p>
            </button>

            <!-- Gift Cards -->
            <button onclick="switchTab('gift-cards')" class="rounded-xl p-6 text-left transition-all border bg-white hover:shadow-lg border-gray-100">
                <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-3 bg-red-100">
                    <svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7"/></svg>
                </div>
                <h3 class="font-bold mb-1 text-gray-900">Gift Cards</h3>
                <p class="text-sm text-gray-500">Manage cards</p>
            </button>

            <!-- Analytics -->
            <button onclick="switchTab('advanced-analytics')" class="rounded-xl p-6 text-left transition-all border bg-white hover:shadow-lg border-gray-100">
                <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-3 bg-emerald-100">
                    <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
                </div>
                <h3 class="font-bold mb-1 text-gray-900">Analytics</h3>
                <p class="text-sm text-gray-500">View reports</p>
            </button>

            <!-- Settings -->
            <button onclick="switchTab('settings')" class="rounded-xl p-6 text-left transition-all border bg-white hover:shadow-lg border-gray-100">
                <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-3 bg-slate-100">
                    <svg class="w-6 h-6 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </div>
                <h3 class="font-bold mb-1 text-gray-900">Settings</h3>
                <p class="text-sm text-gray-500">Configure salon</p>
            </button>
        </div>
    </div>

    <!-- Recent Activity -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <h3 class="text-lg font-bold text-gray-900 mb-4">Recent Bookings</h3>
        <div id="recent-bookings">
            <div class="text-center py-8 text-gray-400 text-sm">Loading recent bookings...</div>
        </div>
    </div>
</div>