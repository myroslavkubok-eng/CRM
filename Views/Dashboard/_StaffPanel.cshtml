<div class="space-y-6">
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-3xl font-bold text-gray-900 mb-2">👥 Staff Management</h1>
            <p class="text-gray-600">Manage your team members</p>
        </div>
        <div class="flex gap-3">
            <button onclick="openInviteStaffModal()" class="px-4 py-2 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50">
                <svg class="w-5 h-5 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/></svg>
                Invite Staff
            </button>
            <button onclick="openAddMasterModalStaff()" class="bg-gradient-to-r from-purple-600 to-pink-600 text-white px-6 py-2.5 rounded-lg font-medium hover:opacity-90">
                + Add Master
            </button>
        </div>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4">
            <p class="text-sm text-gray-500 mb-1">Total Staff</p>
            <p id="staff-total" class="text-2xl font-bold text-gray-900">—</p>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4">
            <p class="text-sm text-gray-500 mb-1">Active Today</p>
            <p id="staff-active" class="text-2xl font-bold text-green-600">—</p>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4">
            <p class="text-sm text-gray-500 mb-1">Masters</p>
            <p id="staff-masters" class="text-2xl font-bold text-purple-600">—</p>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4">
            <p class="text-sm text-gray-500 mb-1">Admins</p>
            <p id="staff-admins" class="text-2xl font-bold text-blue-600">—</p>
        </div>
    </div>

    <!-- Staff Grid -->
    <div id="staff-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="text-center py-12 col-span-full text-gray-400">Loading staff...</div>
    </div>
</div>

<!-- Add Master Modal -->
<div id="add-master-modal-staff" class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-md mx-4 max-h-[90vh] overflow-y-auto">
        <div class="p-6 border-b border-gray-100">
            <div class="flex items-center justify-between">
                <h3 class="text-lg font-bold text-gray-900">Add New Master</h3>
                <button onclick="closeAddMasterModalStaff()" class="text-gray-400 hover:text-gray-600">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
            </div>
        </div>
        <form id="add-master-form-staff" class="p-6 space-y-4">
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">First Name *</label>
                    <input type="text" id="master-first-name-staff" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500"/>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Last Name *</label>
                    <input type="text" id="master-last-name-staff" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500"/>
                </div>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Email *</label>
                <input type="email" id="master-email-staff" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500"/>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Phone</label>
                <input type="tel" id="master-phone-staff" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500"/>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Specialty</label>
                <input type="text" id="master-specialty-staff" placeholder="e.g., Hair Colorist" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500"/>
            </div>
            <div class="flex gap-3 pt-4">
                <button type="button" onclick="closeAddMasterModalStaff()" class="flex-1 px-4 py-2 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50">Cancel</button>
                <button type="submit" class="flex-1 px-4 py-2 bg-gradient-to-r from-purple-600 to-pink-600 text-white rounded-lg hover:opacity-90">Add Master</button>
            </div>
        </form>
    </div>
</div>

<script>
function loadStaff() {
    const token = localStorage.getItem('auth_token') || '';
    fetch('/masters/salon/' + salonId, { headers: { 'Authorization': 'Bearer ' + token } })
        .then(r => r.json())
        .then(data => {
            const masters = data.masters || data || [];
            const total = masters.length;
            
            document.getElementById('staff-total').textContent = total;
            document.getElementById('staff-masters').textContent = masters.length;
            document.getElementById('staff-admins').textContent = '0';
            document.getElementById('staff-active').textContent = Math.floor(total * 0.8);
            
            const grid = document.getElementById('staff-grid');
            if (total === 0) {
                grid.innerHTML = '<div class="text-center py-12 col-span-full"><p class="text-gray-500">No staff members yet</p></div>';
                return;
            }
            
            let html = '';
            masters.forEach(m => {
                const initials = ((m.firstName || 'U')[0] + (m.lastName || '')[0] || 'U');
                const name = (m.firstName || '') + ' ' + (m.lastName || '');
                html += `
                    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-lg transition-shadow">
                        <div class="h-32 bg-gradient-to-br from-purple-100 to-pink-100 flex items-center justify-center">
                            <div class="w-20 h-20 rounded-full bg-white flex items-center justify-center text-2xl font-bold text-purple-600">
                                ${initials}
                            </div>
                        </div>
                        <div class="p-5">
                            <div class="flex items-start justify-between mb-2">
                                <h3 class="font-bold text-gray-900">${name.trim() || 'Master'}</h3>
                                <span class="px-2 py-1 text-xs font-medium rounded-full bg-purple-100 text-purple-700">Master</span>
                            </div>
                            <p class="text-sm text-gray-600 mb-2">${m.email || 'No email'}</p>
                            <p class="text-sm text-gray-500 mb-4">${m.phone || '—'}</p>
                            <div class="flex gap-2">
                                <button onclick="viewStaff('${m.id}')" class="flex-1 px-3 py-2 bg-purple-100 text-purple-700 rounded-lg text-sm font-medium hover:bg-purple-200">View Profile</button>
                                <button onclick="editStaff('${m.id}')" class="px-3 py-2 border border-gray-300 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-50">Edit</button>
                            </div>
                        </div>
                    </div>
                `;
            });
            grid.innerHTML = html;
        })
        .catch(err => {
            console.error('Error loading staff:', err);
            document.getElementById('staff-grid').innerHTML = '<div class="text-center py-12 col-span-full text-red-500">Error loading staff</div>';
        });
}

function openAddMasterModalStaff() {
    document.getElementById('add-master-modal-staff').classList.remove('hidden');
}

function closeAddMasterModalStaff() {
    document.getElementById('add-master-modal-staff').classList.add('hidden');
    document.getElementById('add-master-form-staff').reset();
}

document.getElementById('add-master-form-staff').addEventListener('submit', async function(e) {
    e.preventDefault();
    const token = localStorage.getItem('auth_token') || '';
    const data = {
        firstName: document.getElementById('master-first-name-staff').value.trim(),
        lastName: document.getElementById('master-last-name-staff').value.trim(),
        email: document.getElementById('master-email-staff').value.trim(),
        phone: document.getElementById('master-phone-staff').value.trim(),
        categories: [],
        salonId: salonId
    };
    
    try {
        const resp = await fetch('/masters', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
            body: JSON.stringify(data)
        });
        
        if (resp.ok) {
            closeAddMasterModalStaff();
            loadStaff();
        } else {
            const error = await resp.json();
            alert('Error: ' + (error.message || JSON.stringify(error)));
        }
    } catch (e) {
        alert('Network error: ' + e.message);
    }
});

function openInviteStaffModal() {
    alert('Staff invitation feature coming soon!');
}

function viewStaff(staffId) {
    alert('View staff profile - coming soon!');
}

function editStaff(staffId) {
    alert('Edit staff - coming soon!');
}
</script>