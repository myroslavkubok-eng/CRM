<div class="space-y-6">
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-3xl font-bold text-gray-900 mb-2">Calendar</h1>
            <p class="text-gray-600">Manage your booking schedule</p>
        </div>
        <div class="flex gap-3">
            <select id="calendar-view" onchange="changeCalendarView(this.value)" class="px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500">
                <option value="month">Month View</option>
                <option value="week">Week View</option>
                <option value="day">Day View</option>
            </select>
            <button onclick="openNewBookingModal()" class="bg-gradient-to-r from-purple-600 to-pink-600 text-white px-6 py-2.5 rounded-lg font-medium hover:opacity-90">
                + New Booking
            </button>
        </div>
    </div>

    <!-- Today's Overview -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4">
            <p class="text-sm text-gray-500 mb-1">Today's Bookings</p>
            <p id="calendar-today-count" class="text-2xl font-bold text-gray-900">—</p>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4">
            <p class="text-sm text-gray-500 mb-1">Pending Confirmations</p>
            <p id="calendar-pending-count" class="text-2xl font-bold text-yellow-600">—</p>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4">
            <p class="text-sm text-gray-500 mb-1">Available Slots</p>
            <p id="calendar-available-count" class="text-2xl font-bold text-green-600">—</p>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4">
            <p class="text-sm text-gray-500 mb-1">Estimated Revenue</p>
            <p id="calendar-revenue" class="text-2xl font-bold text-purple-600">$—</p>
        </div>
    </div>

    <!-- Calendar Header -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4">
        <div class="flex items-center justify-between mb-4">
            <div class="flex items-center gap-4">
                <button onclick="previousMonth()" class="p-2 hover:bg-gray-100 rounded-lg">
                    <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                </button>
                <h2 id="calendar-month-year" class="text-xl font-bold text-gray-900">Loading...</h2>
                <button onclick="nextMonth()" class="p-2 hover:bg-gray-100 rounded-lg">
                    <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                </button>
            </div>
            <div class="flex gap-2">
                <button onclick="selectMaster(null)" class="px-3 py-1.5 bg-purple-100 text-purple-700 rounded-lg text-sm font-medium">All Masters</button>
                <select id="master-filter" onchange="selectMaster(this.value)" class="px-4 py-2 border border-gray-300 rounded-lg text-sm">
                    <option value="">Select Master...</option>
                </select>
            </div>
        </div>

        <!-- Calendar Grid -->
        <div id="calendar-grid" class="grid grid-cols-7 gap-1">
            <!-- Days headers -->
            <div class="text-center py-2 text-xs font-semibold text-gray-500">Sun</div>
            <div class="text-center py-2 text-xs font-semibold text-gray-500">Mon</div>
            <div class="text-center py-2 text-xs font-semibold text-gray-500">Tue</div>
            <div class="text-center py-2 text-xs font-semibold text-gray-500">Wed</div>
            <div class="text-center py-2 text-xs font-semibold text-gray-500">Thu</div>
            <div class="text-center py-2 text-xs font-semibold text-gray-500">Fri</div>
            <div class="text-center py-2 text-xs font-semibold text-gray-500">Sat</div>
        </div>
    </div>

    <!-- Upcoming Bookings -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <h3 class="text-lg font-bold text-gray-900 mb-4">Upcoming Bookings</h3>
        <div id="upcoming-bookings-list">
            <div class="text-center py-8 text-gray-400">Loading upcoming bookings...</div>
        </div>
    </div>
</div>

<script>
let currentDate = new Date();
let currentMonth = currentDate.getMonth();
let currentYear = currentDate.getFullYear();

function loadCalendar() {
    const monthNames = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];
    document.getElementById('calendar-month-year').textContent = monthNames[currentMonth] + ' ' + currentYear;
    
    const firstDay = new Date(currentYear, currentMonth, 1);
    const lastDay = new Date(currentYear, currentMonth + 1, 0);
    const startDay = firstDay.getDay();
    const daysInMonth = lastDay.getDate();
    
    let calendarHTML = `
        <div class="text-center py-2 text-xs font-semibold text-gray-500">Sun</div>
        <div class="text-center py-2 text-xs font-semibold text-gray-500">Mon</div>
        <div class="text-center py-2 text-xs font-semibold text-gray-500">Tue</div>
        <div class="text-center py-2 text-xs font-semibold text-gray-500">Wed</div>
        <div class="text-center py-2 text-xs font-semibold text-gray-500">Thu</div>
        <div class="text-center py-2 text-xs font-semibold text-gray-500">Fri</div>
        <div class="text-center py-2 text-xs font-semibold text-gray-500">Sat</div>
    `;
    
    for (let i = 0; i < startDay; i++) {
        calendarHTML += '<div class="min-h-[100px] p-2 bg-gray-50 border border-gray-100"></div>';
    }
    
    const today = new Date();
    for (let day = 1; day <= daysInMonth; day++) {
        const isToday = day === today.getDate() && currentMonth === today.getMonth() && currentYear === today.getFullYear();
        const hasBookings = Math.random() > 0.7;
        
        calendarHTML += `
            <div class="min-h-[100px] p-2 bg-white border border-gray-100 hover:bg-purple-50 cursor-pointer transition-colors ${isToday ? 'ring-2 ring-purple-500' : ''}" onclick="selectDate(${day})">
                <div class="text-sm font-medium mb-1 ${isToday ? 'text-purple-600' : 'text-gray-900'}">${day}</div>
                ${hasBookings ? `
                    <div class="space-y-1">
                        <div class="text-xs bg-purple-100 text-purple-700 px-1 rounded">9:00 AM</div>
                        <div class="text-xs bg-green-100 text-green-700 px-1 rounded">11:00 AM</div>
                    </div>
                ` : ''}
            </div>
        `;
    }
    
    document.getElementById('calendar-grid').innerHTML = calendarHTML;
    loadCalendarStats();
}

function loadCalendarStats() {
    document.getElementById('calendar-today-count').textContent = '8';
    document.getElementById('calendar-pending-count').textContent = '3';
    document.getElementById('calendar-available-count').textContent = '12';
    document.getElementById('calendar-revenue').textContent = '$850';
}

function previousMonth() {
    currentMonth--;
    if (currentMonth < 0) {
        currentMonth = 11;
        currentYear--;
    }
    loadCalendar();
}

function nextMonth() {
    currentMonth++;
    if (currentMonth > 11) {
        currentMonth = 0;
        currentYear++;
    }
    loadCalendar();
}

function selectDate(day) {
    const monthNames = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];
    alert(`Selected: ${monthNames[currentMonth]} ${day}, ${currentYear}\n\nDate detail view coming soon!`);
}

function changeCalendarView(view) {
    console.log('Changing to view:', view);
}

function selectMaster(masterId) {
    console.log('Selected master:', masterId);
}

function openNewBookingModal() {
    alert('New booking modal coming soon!');
}
</script>