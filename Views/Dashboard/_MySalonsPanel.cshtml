<div class="space-y-6">
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-3xl font-bold text-gray-900 mb-2">My Salons</h1>
            <p class="text-gray-600">Manage your salon locations</p>
        </div>
        <button onclick="openAddSalonModal()" class="bg-gradient-to-r from-purple-600 to-pink-600 text-white px-6 py-2.5 rounded-lg font-medium hover:opacity-90 transition-opacity">
            + Add New Salon
        </button>
    </div>

    <div id="salons-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="text-center py-12 text-gray-400 col-span-full">
            Loading your salons...
        </div>
    </div>
</div>

<!-- Add Salon Modal -->
<div id="add-salon-modal" class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-2xl mx-4 max-h-[90vh] overflow-y-auto">
        <div class="p-6 border-b border-gray-100">
            <div class="flex items-center justify-between">
                <h3 class="text-lg font-bold text-gray-900">Add New Salon</h3>
                <button onclick="closeAddSalonModal()" class="text-gray-400 hover:text-gray-600">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
            </div>
        </div>
        <form id="add-salon-form" class="p-6 space-y-4">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Salon Name *</label>
                <input type="text" id="salon-name" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500" placeholder="e.g., Glamour Beauty Studio" />
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Address *</label>
                <input type="text" id="salon-address" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500" placeholder="123 Main St, City" />
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Phone *</label>
                    <input type="tel" id="salon-phone" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500" placeholder="+1 (555) 123-4567" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                    <input type="email" id="salon-email" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500" placeholder="salon@example.com" />
                </div>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
                <textarea id="salon-description" rows="3" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500" placeholder="Describe your salon..."></textarea>
            </div>
            <div class="flex gap-3 pt-4">
                <button type="button" onclick="closeAddSalonModal()" class="flex-1 px-4 py-2 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50">Cancel</button>
                <button type="submit" class="flex-1 px-4 py-2 bg-gradient-to-r from-purple-600 to-pink-600 text-white rounded-lg hover:opacity-90">Add Salon</button>
            </div>
        </form>
    </div>
</div>

<script>
function loadMySalons() {
    const token = localStorage.getItem('auth_token') || '';
    fetch('/salons/user/' + currentUser.id, { headers: { 'Authorization': 'Bearer ' + token } })
        .then(r => r.json())
        .then(data => {
            const salons = data.salons || data || [];
            const grid = document.getElementById('salons-grid');
            if (!salons.length) {
                grid.innerHTML = '<div class="text-center py-12 col-span-full"><p class="text-gray-500">No salons found. Add your first salon!</p></div>';
                return;
            }
            grid.innerHTML = salons.map(salon => `
                <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-lg transition-shadow">
                    <div class="h-40 bg-gradient-to-br from-purple-100 to-pink-100 flex items-center justify-center">
                        ${salon.logo ? `<img src="${salon.logo}" class="w-full h-full object-cover" alt="${salon.name}"/>` : `<svg class="w-20 h-20 text-purple-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>`}
                    </div>
                    <div class="p-5">
                        <div class="flex items-start justify-between mb-2">
                            <h3 class="font-bold text-gray-900">${salon.name || 'Unnamed Salon'}</h3>
                            <span class="px-2 py-1 text-xs font-medium rounded-full ${salon.isPublished ? 'bg-green-100 text-green-700' : 'bg-yellow-100 text-yellow-700'}">${salon.isPublished ? 'Active' : 'Draft'}</span>
                        </div>
                        <p class="text-sm text-gray-600 mb-3">${salon.address || 'No address'}</p>
                        <div class="flex items-center gap-4 text-sm text-gray-500 mb-3">
                            <span>📞 ${salon.phone || 'N/A'}</span>
                        </div>
                        <div class="flex gap-2">
                            <button onclick="switchSalon('${salon.id}')" class="flex-1 px-3 py-2 bg-purple-100 text-purple-700 rounded-lg text-sm font-medium hover:bg-purple-200 transition-colors">Switch to this</button>
                            <button onclick="editSalon('${salon.id}')" class="px-3 py-2 border border-gray-300 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-50 transition-colors">Edit</button>
                        </div>
                    </div>
                </div>
            `).join('');
        })
        .catch(err => {
            console.error('Error loading salons:', err);
            document.getElementById('salons-grid').innerHTML = '<div class="text-center py-12 col-span-full text-red-500">Error loading salons</div>';
        });
}

function openAddSalonModal() {
    document.getElementById('add-salon-modal').classList.remove('hidden');
}

function closeAddSalonModal() {
    document.getElementById('add-salon-modal').classList.add('hidden');
    document.getElementById('add-salon-form').reset();
}

document.getElementById('add-salon-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    const token = localStorage.getItem('auth_token') || '';
    const salonData = {
        name: document.getElementById('salon-name').value.trim(),
        address: document.getElementById('salon-address').value.trim(),
        phone: document.getElementById('salon-phone').value.trim(),
        email: document.getElementById('salon-email').value.trim(),
        description: document.getElementById('salon-description').value.trim(),
    };
    
    try {
        const resp = await fetch('/salons', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': 'Bearer ' + token
            },
            body: JSON.stringify(salonData)
        });
        
        if (resp.ok) {
            closeAddSalonModal();
            loadMySalons();
        } else {
            const error = await resp.json();
            alert('Error: ' + (error.message || JSON.stringify(error)));
        }
    } catch (e) {
        alert('Network error: ' + e.message);
    }
});

function switchSalon(newSalonId) {
    salonId = newSalonId;
    console.log('Switched to salon:', newSalonId);
    
    // Update sidebar salon name
    const grid = document.getElementById('salons-grid');
    const salonCards = grid.querySelectorAll('.bg-white');
    let selectedSalonName = '';
    salonCards.forEach(card => {
        const button = card.querySelector('button[onclick*="switchSalon"]');
        if (button && button.getAttribute('onclick').includes(newSalonId)) {
            selectedSalonName = card.querySelector('h3').textContent;
        }
    });
    
    if (selectedSalonName) {
        document.getElementById('salon-name-sidebar').textContent = selectedSalonName;
    }
    
    // Store selected salon in localStorage
    localStorage.setItem('selected_salon_id', newSalonId);
    
    // Switch to overview and reload data
    switchTab('overview');
}

function editSalon(salonId) {
    alert('Edit salon functionality coming soon!');
}
</script>