    <script>
        // Sign-in dropdown
        function toggleSignIn(e) {
            e.stopPropagation();
            document.getElementById('signinDropdown').classList.toggle('hidden');
        }
        document.addEventListener('click', function() {
            document.getElementById('signinDropdown').classList.add('hidden');
            document.getElementById('user-dropdown-home')?.classList.add('hidden');
        });

        // Check auth state
        async function checkAuthHome() {
            const token = localStorage.getItem('auth_token');
            const userData = localStorage.getItem('user_data');
        
            if (!token || !userData) {
                document.getElementById('auth-buttons-home').classList.remove('hidden');
                document.getElementById('user-menu-home').classList.add('hidden');
                return;
            }
        
            try {
                const user = JSON.parse(userData);
                const resp = await fetch('/auth/me', { headers: { 'Authorization': 'Bearer ' + token } });
            
                if (resp.ok) {
                    document.getElementById('auth-buttons-home').classList.add('hidden');
                    document.getElementById('user-menu-home').classList.remove('hidden');
                    document.getElementById('user-initial-home').textContent = (user.fullName || user.email || '?')[0].toUpperCase();
                    document.getElementById('user-name-home').textContent = user.fullName || user.email || '';
                
                    const role = user.role || 'Client';
                    const dashboards = { SuperAdmin: '/superadmin', Owner: '/owner', Admin: '/admin', Master: '/master', Client: '/client' };
                    document.getElementById('dashboard-link-home').href = dashboards[role] || '/client';
                } else {
                    document.getElementById('auth-buttons-home').classList.remove('hidden');
                    document.getElementById('user-menu-home').classList.add('hidden');
                }
            } catch (e) {
                document.getElementById('auth-buttons-home').classList.remove('hidden');
                document.getElementById('user-menu-home').classList.add('hidden');
            }
        }

        function toggleUserMenuHome(e) {
            e?.stopPropagation();
            document.getElementById('user-dropdown-home').classList.toggle('hidden');
        }

        function signOutHome() {
            localStorage.removeItem('auth_token');
            localStorage.removeItem('user_data');
            window.location.reload();
        }

        checkAuthHome();

        // City data
        const citiesData = {
            uae: ['Dubai', 'Abu Dhabi', 'Sharjah', 'Ajman'],
            usa: ['New York', 'Los Angeles', 'Chicago', 'Miami', 'San Francisco'],
            uk: ['London', 'Manchester', 'Birmingham', 'Liverpool'],
            russia: ['Moscow', 'Saint Petersburg', 'Novosibirsk', 'Kazan'],
            france: ['Paris', 'Marseille', 'Lyon', 'Toulouse'],
            germany: ['Berlin', 'Munich', 'Frankfurt', 'Hamburg'],
            italy: ['Rome', 'Milan', 'Naples', 'Turin'],
            spain: ['Madrid', 'Barcelona', 'Valencia', 'Seville'],
            turkey: ['Istanbul', 'Ankara', 'Izmir', 'Bursa'],
            australia: ['Sydney', 'Melbourne', 'Brisbane', 'Perth']
        };

        function updateCities() {
            const country = document.getElementById('countrySelect').value;
            const citySelect = document.getElementById('citySelect');
            citySelect.innerHTML = '<option value="">City</option>';
            if (citiesData[country]) {
                citiesData[country].forEach(city => {
                    const opt = document.createElement('option');
                    opt.value = city.toLowerCase().replace(/\s+/g, '');
                    opt.textContent = city;
                    citySelect.appendChild(opt);
                });
            }
        }

        function doSearch() {
            const q = document.getElementById('searchQuery').value;
            const cat = document.getElementById('categorySelect').value;
            const city = document.getElementById('citySelect').value;
            let url = '/Salon/Listing?';
            if (q) url += 'q=' + encodeURIComponent(q) + '&';
            if (cat) url += 'category=' + encodeURIComponent(cat) + '&';
            if (city) url += 'city=' + encodeURIComponent(city) + '&';
            window.location.href = url;
        }

        // Testimonials
        const testimonials = [
            { initials: 'OC', name: 'Olivia Chen', text: '"The variety of salons and services is incredible! I found the perfect place for my wedding makeup. The reviews helped me make the right choice. Thank you Katia!"', info: 'Bridal Makeup &bull; Beauty Haven &bull; Dubai, UAE &bull; 1 week ago' },
            { initials: 'EM', name: 'Emma Martinez', text: '"I love how I can book appointments instantly through the app! No more waiting for callbacks. The reminders are super helpful too. Best beauty booking platform I\'ve used!"', info: 'Manicure &amp; Pedicure &bull; Nail Art Paradise &bull; Abu Dhabi, UAE &bull; 3 days ago' },
            { initials: 'SJ', name: 'Sarah Johnson', text: '"Amazing platform! Found the perfect salon for my needs. The booking process was seamless and the staff was professional. Highly recommend!"', info: 'Hair Styling &bull; Glamour Studio &bull; Dubai, UAE &bull; 2 weeks ago' }
        ];
        let currentT = 0;

        function renderTestimonial(idx) {
            const t = testimonials[idx];
            document.getElementById('tAvatar').textContent = t.initials;
            document.getElementById('tName').textContent = t.name;
            document.getElementById('tText').textContent = t.text;
            document.getElementById('tInfo').innerHTML = t.info;
            const dots = document.getElementById('testimonialDots').children;
            for (let i = 0; i < dots.length; i++) {
                dots[i].className = i === idx
                    ? 'h-2 rounded-full transition-all w-8 bg-gradient-to-r from-purple-600 to-pink-600'
                    : 'h-2 rounded-full transition-all w-2 bg-gray-300';
            }
        }
        function nextTestimonial() { currentT = (currentT + 1) % testimonials.length; renderTestimonial(currentT); }
        function prevTestimonial() { currentT = (currentT - 1 + testimonials.length) % testimonials.length; renderTestimonial(currentT); }
        function goToTestimonial(i) { currentT = i; renderTestimonial(i); }

        // Animated counters
        let bookings = 10000, clients = 10000, salons = 500;
        setInterval(() => { bookings += Math.floor(Math.random() * 3) + 1; document.getElementById('bookingsCount').textContent = bookings.toLocaleString() + '+'; }, 2000);
        setInterval(() => { clients += Math.floor(Math.random() * 2) + 1; document.getElementById('clientsCount').textContent = clients.toLocaleString() + '+'; }, 3000);
        setInterval(() => { if (Math.random() > 0.7) { salons++; document.getElementById('salonsCount').textContent = salons.toLocaleString() + '+'; } }, 5000);
    </script>
</body>
</html>
