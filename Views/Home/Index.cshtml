@{
    ViewData["Title"] = "Katia Booking - Beauty & Wellness Marketplace";
}

<!DOCTYPE html>
<html lang="en">
<head>
    @* Tailwind CDN for Razor views (compiled CSS may not include all classes) *@
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
    <!-- Header -->
    <header class="sticky top-0 z-50 bg-white border-b border-gray-200 shadow-sm">
        <div class="container mx-auto px-4 py-3">
            <div class="flex items-center justify-between">
                <a href="/" class="flex items-center gap-2">
                    <img src="/icons/logo.svg" alt="Katia Booking" class="w-10 h-10 rounded-xl" onerror="this.style.background='linear-gradient(135deg,#9333ea,#ec4899)';this.style.display='flex'" />
                    <span class="text-xl font-bold text-gray-900 hidden sm:inline">Katia Booking</span>
                </a>

                <nav class="hidden md:flex items-center gap-6">
                    <a href="/Salon/Listing" class="flex items-center gap-2 text-sm font-medium text-gray-700 hover:text-purple-600 transition-colors">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
                        <span>Browse by Category</span>
                    </a>
                    <a href="/Admin/BecomePartner" class="flex items-center gap-2 text-sm font-medium text-purple-600 hover:text-purple-700 transition-colors">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
                        <span>Become a Partner</span>
                    </a>
                    <a href="/Contact" class="flex items-center gap-2 text-sm font-medium text-gray-700 hover:text-purple-600 transition-colors">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                        <span>Support</span>
                    </a>
                </nav>

                <div class="flex items-center gap-3">
                    <div id="auth-buttons-home">
                        <div class="relative">
                            <button onclick="toggleSignIn(event)" class="flex items-center gap-2 px-4 py-2 bg-gradient-to-r from-purple-600 to-pink-600 hover:from-purple-700 hover:to-pink-700 text-white rounded-md text-sm font-medium transition-all">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
                                <span class="hidden sm:inline">Sign In</span>
                            </button>
                            <div id="signinDropdown" class="hidden absolute right-0 mt-2 w-56 bg-white rounded-xl shadow-xl border border-gray-100 z-50 py-1">
                                <p class="px-4 py-2 text-xs font-semibold text-gray-500 uppercase tracking-wide">Choose Login Type</p>
                                <a href="/Auth?type=client" class="flex items-center gap-3 px-4 py-2 hover:bg-purple-50 transition-colors">
                                    <svg class="w-4 h-4 text-purple-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                                    <div>
                                        <div class="text-sm font-medium text-gray-900">Sign in as Client</div>
                                        <div class="text-xs text-gray-500">Book appointments</div>
                                    </div>
                                </a>
                                <a href="/Auth?type=salon" class="flex items-center gap-3 px-4 py-2 hover:bg-purple-50 transition-colors">
                                    <svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>
                                    <div>
                                        <div class="text-sm font-medium text-gray-900">Sign in as Salon</div>
                                        <div class="text-xs text-gray-500">Manage your business</div>
                                    </div>
                                </a>
                            </div>
                        </div>
                    </div>
                    <div id="user-menu-home" class="hidden relative">
                        <button onclick="toggleUserMenuHome(event)" class="flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-purple-50 transition-colors">
                            <div class="w-8 h-8 bg-gradient-to-r from-purple-600 to-pink-600 rounded-full flex items-center justify-center">
                                <span id="user-initial-home" class="text-white font-bold text-sm">?</span>
                            </div>
                            <span id="user-name-home" class="text-sm font-medium text-gray-700 hidden sm:inline"></span>
                            <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                        </button>
                        <div id="user-dropdown-home" class="hidden absolute right-0 mt-2 w-48 bg-white rounded-xl shadow-xl border border-gray-100 z-50 py-1">
                            <a id="dashboard-link-home" href="#" class="block px-4 py-2 text-sm text-gray-700 hover:bg-purple-50">My Dashboard</a>
                            <button onclick="signOutHome()" class="w-full text-left px-4 py-2 text-sm text-red-600 hover:bg-red-50">Sign Out</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- Hero Section -->
    <div class="bg-gradient-to-b from-purple-50 via-pink-50 to-white py-16 md:py-24">
        <div class="container mx-auto px-3 md:px-4">
            <div class="max-w-4xl mx-auto text-center mb-6">
                <div class="inline-flex items-center gap-2 px-4 py-2 bg-purple-100 rounded-full mb-6">
                    <svg class="w-4 h-4 text-purple-600" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z"/></svg>
                    <span class="text-sm text-purple-600 font-medium">Your Premier Luxury Beauty Platform</span>
                </div>
            </div>

            <div class="max-w-4xl mx-auto text-center mb-8">
                <h1 class="text-4xl md:text-6xl font-bold mb-4">
                    <span class="text-gray-900">Welcome to</span>
                    <br>
                    <span class="bg-gradient-to-r from-purple-600 to-pink-600 bg-clip-text text-transparent">Katia Booking</span>
                </h1>
                <p class="text-lg md:text-xl text-purple-600 mb-8">Discover and book the finest beauty salons</p>

                <div class="flex justify-center gap-4 md:gap-8 mb-12">
                    <div class="bg-white rounded-2xl px-6 py-4 shadow-sm">
                        <div class="text-2xl md:text-3xl font-bold bg-gradient-to-r from-purple-600 to-pink-600 bg-clip-text text-transparent">12+</div>
                        <div class="text-xs md:text-sm text-gray-600">Salons</div>
                    </div>
                    <div class="bg-white rounded-2xl px-6 py-4 shadow-sm">
                        <div class="text-2xl md:text-3xl font-bold bg-gradient-to-r from-purple-600 to-pink-600 bg-clip-text text-transparent">50K+</div>
                        <div class="text-xs md:text-sm text-gray-600">Clients</div>
                    </div>
                    <div class="bg-white rounded-2xl px-6 py-4 shadow-sm">
                        <div class="text-2xl md:text-3xl font-bold bg-gradient-to-r from-purple-600 to-pink-600 bg-clip-text text-transparent">4.8&#9733;</div>
                        <div class="text-xs md:text-sm text-gray-600">Rating</div>
                    </div>
                </div>
            </div>

            <!-- Smart Search Box -->
            <div class="max-w-5xl mx-auto">
                <div class="bg-white rounded-3xl shadow-2xl p-6 md:p-8">
                    <div class="flex items-center gap-2 mb-6">
                        <svg class="w-5 h-5 text-purple-600" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z"/></svg>
                        <span class="text-sm font-medium text-purple-600">Smart Search</span>
                        <a href="#" class="ml-auto flex items-center gap-2 px-3 py-1.5 bg-gradient-to-r from-purple-600 to-pink-600 rounded-full hover:from-purple-700 hover:to-pink-700 transition-all hover:shadow-lg cursor-pointer">
                            <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z"/></svg>
                            <span class="text-xs font-medium text-white">AI Katia</span>
                        </a>
                    </div>

                    <div class="mb-4">
                        <div class="relative">
                            <svg class="absolute left-4 top-1/2 transform -translate-y-1/2 w-5 h-5 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                            <input type="text" id="searchQuery" placeholder="Search services, salons..." class="w-full pl-12 h-14 text-base rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-purple-400 focus:border-transparent px-4" />
                        </div>
                    </div>

                    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
                        <select id="countrySelect" onchange="updateCities()" class="h-12 rounded-xl border border-gray-200 px-3 text-sm focus:outline-none focus:ring-2 focus:ring-purple-400 bg-white">
                            <option value="">Country</option>
                            <option value="uae">&#127462;&#127466; UAE</option>
                            <option value="usa">&#127482;&#127480; USA</option>
                            <option value="uk">&#127468;&#127463; UK</option>
                            <option value="russia">&#127479;&#127482; Russia</option>
                            <option value="france">&#127467;&#127479; France</option>
                            <option value="germany">&#127465;&#127466; Germany</option>
                            <option value="italy">&#127470;&#127481; Italy</option>
                            <option value="spain">&#127466;&#127480; Spain</option>
                            <option value="turkey">&#127481;&#127479; Turkey</option>
                            <option value="australia">&#127462;&#127482; Australia</option>
                        </select>

                        <select id="citySelect" class="h-12 rounded-xl border border-gray-200 px-3 text-sm focus:outline-none focus:ring-2 focus:ring-purple-400 bg-white">
                            <option value="">City</option>
                        </select>

                        <select id="areaSelect" class="h-12 rounded-xl border border-gray-200 px-3 text-sm focus:outline-none focus:ring-2 focus:ring-purple-400 bg-white">
                            <option value="">Area</option>
                            <option>Downtown</option>
                            <option>Marina</option>
                            <option>City Center</option>
                            <option>Suburbs</option>
                        </select>

                        <select id="categorySelect" class="h-12 rounded-xl border border-gray-200 px-3 text-sm focus:outline-none focus:ring-2 focus:ring-purple-400 bg-white">
                            <option value="">Category</option>
                            <option value="manicure">Manicure</option>
                            <option value="pedicure">Pedicure</option>
                            <option value="eyelashes">Eyelashes</option>
                            <option value="brow">Brow</option>
                            <option value="barber">Barber</option>
                            <option value="cosmetology">Cosmetology</option>
                            <option value="laser">Laser</option>
                            <option value="makeup">Make up</option>
                            <option value="hairstylist">Hair Stylist</option>
                            <option value="tattoo">Tattoo</option>
                            <option value="piercing">Piercing</option>
                            <option value="spa">Spa</option>
                            <option value="massage">Massage</option>
                            <option value="waxing">Waxing</option>
                            <option value="facial">Facial</option>
                            <option value="fitness">Fitness</option>
                            <option value="other">Other</option>
                        </select>
                    </div>

                    <button onclick="doSearch()" class="inline-flex items-center mt-4 h-12 px-8 bg-gradient-to-r from-purple-600 to-pink-600 hover:from-purple-700 hover:to-pink-700 text-white rounded-xl font-medium transition-all">
                        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                        Search
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="container mx-auto px-4">

        <!-- Featured Salons -->
        <section class="py-12 md:py-16">
            <div class="flex items-center justify-between mb-6">
                <div>
                    <h2 class="text-2xl md:text-3xl font-bold bg-gradient-to-r from-yellow-600 to-orange-600 bg-clip-text text-transparent flex items-center gap-2">
                        <svg class="w-8 h-8 text-yellow-500" fill="currentColor" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                        Premium Salons
                    </h2>
                    <p class="text-gray-600 text-sm mt-1">Luxury experiences with exclusive services</p>
                </div>
                <a href="/Salon/Listing" class="hidden md:inline-flex items-center px-4 py-2 border border-gray-200 rounded-md text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors">View All</a>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
                <!-- Card 1 -->
                <div class="bg-white rounded-2xl shadow-md overflow-hidden border border-gray-100 hover:shadow-xl transition-shadow">
                    <div class="relative h-48">
                        <img src="https://images.unsplash.com/photo-1560066984-138dadb4c035?w=400&q=80" alt="Beauty Haven Dubai" class="w-full h-full object-cover" />
                        <div class="absolute top-3 left-3"><span class="bg-yellow-500 text-white text-xs font-bold px-2 py-1 rounded-full">Premium</span></div>
                        <button class="absolute top-3 right-3 w-8 h-8 bg-white rounded-full flex items-center justify-center shadow-md hover:scale-110 transition-transform">
                            <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                        </button>
                    </div>
                    <div class="p-4">
                        <h3 class="font-bold text-gray-900 mb-1">Beauty Haven Dubai</h3>
                        <p class="text-xs text-gray-500 mb-2 flex items-center gap-1">
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                            Downtown Dubai &bull; 1.2 km
                        </p>
                        <div class="flex items-center gap-1 mb-3">
                            <svg class="w-4 h-4 text-yellow-400 fill-yellow-400" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                            <span class="text-sm font-semibold">4.9</span>
                            <span class="text-xs text-gray-500">(248 reviews)</span>
                        </div>
                        <div class="flex flex-wrap gap-1 mb-3">
                            <span class="text-xs bg-purple-100 text-purple-700 px-2 py-0.5 rounded-full">Manicure</span>
                            <span class="text-xs bg-pink-100 text-pink-700 px-2 py-0.5 rounded-full">Spa</span>
                        </div>
                        <div class="flex items-center justify-between">
                            <span class="text-sm font-semibold text-purple-600">from AED 150</span>
                            <a href="/Salon/Booking" class="text-xs bg-gradient-to-r from-purple-600 to-pink-600 text-white px-3 py-1.5 rounded-lg hover:from-purple-700 hover:to-pink-700 transition-all">Book Now</a>
                        </div>
                    </div>
                </div>

                <!-- Card 2 -->
                <div class="bg-white rounded-2xl shadow-md overflow-hidden border border-gray-100 hover:shadow-xl transition-shadow">
                    <div class="relative h-48">
                        <img src="https://images.unsplash.com/photo-1522337360788-8b13dee7a37e?w=400&q=80" alt="Glamour Studio" class="w-full h-full object-cover" />
                        <div class="absolute top-3 left-3"><span class="bg-green-500 text-white text-xs font-bold px-2 py-1 rounded-full">Open Now</span></div>
                        <button class="absolute top-3 right-3 w-8 h-8 bg-white rounded-full flex items-center justify-center shadow-md hover:scale-110 transition-transform">
                            <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                        </button>
                    </div>
                    <div class="p-4">
                        <h3 class="font-bold text-gray-900 mb-1">Glamour Studio</h3>
                        <p class="text-xs text-gray-500 mb-2 flex items-center gap-1">
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                            Dubai Marina &bull; 2.1 km
                        </p>
                        <div class="flex items-center gap-1 mb-3">
                            <svg class="w-4 h-4 text-yellow-400 fill-yellow-400" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                            <span class="text-sm font-semibold">4.7</span>
                            <span class="text-xs text-gray-500">(183 reviews)</span>
                        </div>
                        <div class="flex flex-wrap gap-1 mb-3">
                            <span class="text-xs bg-purple-100 text-purple-700 px-2 py-0.5 rounded-full">Hair Styling</span>
                            <span class="text-xs bg-pink-100 text-pink-700 px-2 py-0.5 rounded-full">Makeup</span>
                        </div>
                        <div class="flex items-center justify-between">
                            <span class="text-sm font-semibold text-purple-600">from AED 200</span>
                            <a href="/Salon/Booking" class="text-xs bg-gradient-to-r from-purple-600 to-pink-600 text-white px-3 py-1.5 rounded-lg hover:from-purple-700 hover:to-pink-700 transition-all">Book Now</a>
                        </div>
                    </div>
                </div>

                <!-- Card 3 -->
                <div class="bg-white rounded-2xl shadow-md overflow-hidden border border-gray-100 hover:shadow-xl transition-shadow">
                    <div class="relative h-48">
                        <img src="https://images.unsplash.com/photo-1604654894610-df63bc536371?w=400&q=80" alt="Nail Art Paradise" class="w-full h-full object-cover" />
                        <div class="absolute top-3 left-3"><span class="bg-purple-500 text-white text-xs font-bold px-2 py-1 rounded-full">New</span></div>
                        <button class="absolute top-3 right-3 w-8 h-8 bg-white rounded-full flex items-center justify-center shadow-md hover:scale-110 transition-transform">
                            <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                        </button>
                    </div>
                    <div class="p-4">
                        <h3 class="font-bold text-gray-900 mb-1">Nail Art Paradise</h3>
                        <p class="text-xs text-gray-500 mb-2 flex items-center gap-1">
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                            Business Bay &bull; 0.8 km
                        </p>
                        <div class="flex items-center gap-1 mb-3">
                            <svg class="w-4 h-4 text-yellow-400 fill-yellow-400" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                            <span class="text-sm font-semibold">4.8</span>
                            <span class="text-xs text-gray-500">(94 reviews)</span>
                        </div>
                        <div class="flex flex-wrap gap-1 mb-3">
                            <span class="text-xs bg-purple-100 text-purple-700 px-2 py-0.5 rounded-full">Manicure</span>
                            <span class="text-xs bg-pink-100 text-pink-700 px-2 py-0.5 rounded-full">Pedicure</span>
                        </div>
                        <div class="flex items-center justify-between">
                            <span class="text-sm font-semibold text-purple-600">from AED 80</span>
                            <a href="/Salon/Booking" class="text-xs bg-gradient-to-r from-purple-600 to-pink-600 text-white px-3 py-1.5 rounded-lg hover:from-purple-700 hover:to-pink-700 transition-all">Book Now</a>
                        </div>
                    </div>
                </div>

                <!-- Card 4 -->
                <div class="bg-white rounded-2xl shadow-md overflow-hidden border border-gray-100 hover:shadow-xl transition-shadow">
                    <div class="relative h-48">
                        <img src="https://images.unsplash.com/photo-1487412947147-5cebf100d6a6?w=400&q=80" alt="The Spa Lounge" class="w-full h-full object-cover" />
                        <div class="absolute top-3 left-3"><span class="bg-blue-500 text-white text-xs font-bold px-2 py-1 rounded-full">Top Rated</span></div>
                        <button class="absolute top-3 right-3 w-8 h-8 bg-white rounded-full flex items-center justify-center shadow-md hover:scale-110 transition-transform">
                            <svg class="w-4 h-4 text-pink-500 fill-pink-500" viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                        </button>
                    </div>
                    <div class="p-4">
