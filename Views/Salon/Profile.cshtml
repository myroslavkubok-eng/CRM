@{
    Layout = null;
    ViewData["Title"] = "Salon Profile";
    ViewData["Description"] = "View salon details, services, masters and book an appointment.";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Katia Beauty Platform</title>
    <meta name="description" content="@ViewData["Description"]" />
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen bg-gray-50">

    <!-- Header -->
    <header class="bg-white/80 backdrop-blur-md border-b border-purple-100 sticky top-0 z-50">
        <div class="container mx-auto px-4 py-4 flex items-center justify-between max-w-6xl">
            <a href="/" class="flex items-center gap-2">
                <div class="w-8 h-8 bg-gradient-to-r from-purple-600 to-pink-600 rounded-lg flex items-center justify-center">
                    <span class="text-white font-bold text-sm">K</span>
                </div>
                <span class="font-bold text-xl bg-gradient-to-r from-purple-600 to-pink-600 bg-clip-text text-transparent">Katia</span>
            </a>
            <nav class="hidden md:flex items-center gap-6">
                <a href="/salon/listing" class="text-gray-600 hover:text-purple-600 transition-colors text-sm font-medium">Find Salons</a>
                <a href="/auth" class="bg-gradient-to-r from-purple-600 to-pink-600 text-white px-4 py-2 rounded-lg text-sm font-medium hover:opacity-90 transition-opacity">Sign In</a>
            </nav>
        </div>
    </header>

    <div class="container mx-auto px-4 py-6 max-w-6xl">

        <!-- Back Button -->
        <a href="/salon/listing" class="flex items-center gap-2 text-gray-600 hover:text-purple-600 mb-4 transition-colors w-fit">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
            </svg>
            <span class="font-medium">Back to Salons</span>
        </a>

        <!-- Loading State -->
        <div id="loading-state">
            <div class="w-full h-72 bg-gray-200 animate-pulse rounded-2xl mb-6"></div>
            <div class="grid md:grid-cols-3 gap-6">
                <div class="md:col-span-2 space-y-4">
                    <div class="h-8 bg-gray-200 animate-pulse rounded w-2/3"></div>
                    <div class="h-4 bg-gray-200 animate-pulse rounded w-1/2"></div>
                    <div class="h-32 bg-gray-200 animate-pulse rounded"></div>
                </div>
                <div class="h-64 bg-gray-200 animate-pulse rounded-xl"></div>
            </div>
        </div>

        <!-- Salon Content (populated by JS) -->
        <div id="salon-content" class="hidden">

            <!-- Photo Gallery -->
            <div id="gallery-container" class="w-full h-72 bg-gradient-to-br from-purple-100 to-pink-100 rounded-2xl mb-6 overflow-hidden relative">
                <div class="w-full h-full flex items-center justify-center">
                    <span class="text-8xl">✂️</span>
                </div>
            </div>

            <div class="grid md:grid-cols-3 gap-6">

                <!-- Main Info -->
                <div class="md:col-span-2 space-y-6">

                    <!-- Name and Rating -->
                    <div class="bg-white rounded-xl p-6 shadow-sm">
                        <div class="flex items-start justify-between">
                            <div>
                                <h1 id="salon-name" class="text-3xl font-bold text-gray-900 mb-2"></h1>
                                <div class="flex items-center gap-2 mb-3">
                                    <div class="flex items-center gap-1">
                                        <svg class="w-5 h-5 text-yellow-400 fill-current" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                                        <span id="salon-rating" class="font-bold text-gray-900 text-lg"></span>
                                    </div>
                                    <span id="salon-reviews" class="text-gray-500 text-sm"></span>
                                    <span id="salon-open" class="px-2 py-0.5 rounded-full text-xs font-bold bg-green-100 text-green-700 hidden">Open Now</span>
                                </div>
                                <p id="salon-location" class="text-gray-600 flex items-center gap-1.5">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                                    </svg>
                                    <span id="salon-address"></span>
                                </p>
                            </div>
                            <button onclick="toggleFavorite()" id="fav-btn"
                                class="w-10 h-10 rounded-full border-2 border-gray-200 flex items-center justify-center hover:border-red-300 transition-colors">
                                <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                                </svg>
                            </button>
                        </div>
                    </div>

                    <!-- About -->
                    <div class="bg-white rounded-xl p-6 shadow-sm">
                        <h2 class="text-xl font-bold mb-3">About</h2>
                        <p id="salon-description" class="text-gray-600 leading-relaxed"></p>
                    </div>

                    <!-- Services -->
                    <div class="bg-white rounded-xl p-6 shadow-sm">
                        <h2 class="text-xl font-bold mb-4">Services</h2>
                        <div id="services-list" class="space-y-3"></div>
                    </div>

                    <!-- Masters -->
                    <div class="bg-white rounded-xl p-6 shadow-sm" id="masters-section">
                        <h2 class="text-xl font-bold mb-4">Our Team</h2>
                        <div id="masters-list" class="grid grid-cols-2 sm:grid-cols-3 gap-4"></div>
                    </div>
                </div>

                <!-- Booking Sidebar -->
                <div class="space-y-4">
                    <div class="bg-white rounded-xl p-6 shadow-sm sticky top-24">
                        <h2 class="text-lg font-bold mb-4">Book Appointment</h2>
                        <a id="book-btn" href="#"
                            class="block w-full h-12 bg-gradient-to-r from-purple-600 to-pink-600 hover:from-purple-700 hover:to-pink-700 text-white font-semibold rounded-lg transition-all flex items-center justify-center gap-2">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                            </svg>
                            Book Now
                        </a>

                        <!-- Contact Info -->
                        <div class="mt-4 space-y-3 pt-4 border-t border-gray-100">
                            <div id="contact-phone" class="hidden flex items-center gap-2 text-sm text-gray-600">
                                <svg class="w-4 h-4 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                                </svg>
                                <span id="salon-phone"></span>
                            </div>
                            <div id="contact-email" class="hidden flex items-center gap-2 text-sm text-gray-600">
                                <svg class="w-4 h-4 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                                </svg>
                                <span id="salon-email"></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Error State -->
        <div id="error-state" class="hidden text-center py-20">
            <p class="text-gray-500 text-lg mb-4">Salon not found</p>
            <a href="/salon/listing" class="text-purple-600 hover:underline font-medium">Browse all salons</a>
        </div>
    </div>

    <!-- Footer -->
    <footer class="bg-gray-900 text-gray-400 py-12 mt-16">
        <div class="container mx-auto px-4 max-w-6xl">
            <div class="flex flex-col md:flex-row items-center justify-between gap-4">
                <div class="flex items-center gap-2">
                    <div class="w-8 h-8 bg-gradient-to-r from-purple-600 to-pink-600 rounded-lg flex items-center justify-center">
                        <span class="text-white font-bold text-sm">K</span>
                    </div>
                    <span class="text-white font-bold text-lg">Katia</span>
                </div>
                <p class="text-sm">&copy; 2024 Katia Beauty Platform. All rights reserved.</p>
            </div>
        </div>
    </footer>

<script>
const pathParts = window.location.pathname.split('/');
const salonId = pathParts[pathParts.length - 1];
let isFav = false;

async function loadSalon() {
    try {
        const resp = await fetch('/api/salons/' + salonId);
        if (!resp.ok) throw new Error();
        const data = await resp.json();
        const salon = data.salon || data;
        displaySalon(salon);
    } catch {
        document.getElementById('loading-state').classList.add('hidden');
        document.getElementById('error-state').classList.remove('hidden');
    }
}

function displaySalon(salon) {
    document.getElementById('loading-state').classList.add('hidden');
    document.getElementById('salon-content').classList.remove('hidden');
    document.title = salon.name + ' - Katia Beauty Platform';

    document.getElementById('salon-name').textContent = salon.name;
    document.getElementById('salon-rating').textContent = (salon.rating || 4.5).toFixed(1);
    document.getElementById('salon-reviews').textContent = '(' + (salon.reviewCount || 0) + ' reviews)';
    document.getElementById('salon-address').textContent = salon.address || salon.city || 'Location not provided';
    document.getElementById('salon-description').textContent = salon.description || 'A premier beauty salon offering top-notch services.';
    document.getElementById('book-btn').href = '/salon/booking/' + salon.id;

    if (salon.isOpenNow) document.getElementById('salon-open').classList.remove('hidden');
    if (salon.phone) {
        document.getElementById('salon-phone').textContent = salon.phone;
        document.getElementById('contact-phone').classList.remove('hidden');
    }
    if (salon.email) {
        document.getElementById('salon-email').textContent = salon.email;
        document.getElementById('contact-email').classList.remove('hidden');
    }
    if (salon.imageUrl) {
        document.getElementById('gallery-container').innerHTML = '<img src="' + salon.imageUrl + '" class="w-full h-full object-cover" alt="' + salon.name + '" />';
    }

    // Services
    const services = salon.services || [];
    const servicesList = document.getElementById('services-list');
    if (services.length) {
        servicesList.innerHTML = services.map(s => `
            <div class="flex items-center justify-between py-3 border-b border-gray-100 last:border-0">
                <div>
                    <p class="font-medium text-gray-900">${s.name}</p>
                    <p class="text-sm text-gray-500">${s.duration || 60} min</p>
                </div>
                <div class="text-right">
                    <p class="font-bold text-purple-600">AED ${s.price || 0}</p>
                    <button onclick="window.location.href='/salon/booking/${salon.id}'"
                        class="text-xs text-purple-600 hover:underline">Book</button>
                </div>
            </div>
        `).join('');
    } else {
        servicesList.innerHTML = '<p class="text-gray-500 text-sm">No services listed yet.</p>';
    }
}

function toggleFavorite() {
    isFav = !isFav;
    const btn = document.getElementById('fav-btn');
    btn.innerHTML = isFav
        ? '<svg class="w-5 h-5 text-red-500 fill-current" viewBox="0 0 24 24"><path d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>'
        : '<svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>';
}

if (salonId && salonId !== 'profile') {
    loadSalon();
} else {
    document.getElementById('loading-state').classList.add('hidden');
    document.getElementById('error-state').classList.remove('hidden');
}
</script>
</body>
</html>


