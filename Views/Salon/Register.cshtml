@{
    Layout = null;
    ViewData["Title"] = "Register Your Salon";
    ViewData["Description"] = "Set up your beauty salon on Katia - choose a plan and start managing bookings.";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Katia Beauty Platform</title>
    <meta name="description" content="@ViewData["Description"]" />
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen bg-gradient-to-br from-purple-50 via-pink-50 to-purple-50">

    <!-- Header -->
    <header class="bg-white/80 backdrop-blur-md border-b border-purple-100 sticky top-0 z-50">
        <div class="container mx-auto px-4 py-4 flex items-center justify-between max-w-6xl">
            <a href="/" class="flex items-center gap-2">
                <div class="w-8 h-8 bg-gradient-to-r from-purple-600 to-pink-600 rounded-lg flex items-center justify-center">
                    <span class="text-white font-bold text-sm">K</span>
                </div>
                <span class="font-bold text-xl bg-gradient-to-r from-purple-600 to-pink-600 bg-clip-text text-transparent">Katia</span>
            </a>
            <div class="text-sm text-gray-600">
                Already have an account?
                <a href="/auth" class="text-purple-600 hover:underline font-medium ml-1">Sign In</a>
            </div>
        </div>
    </header>

    <div class="py-12 px-4">
        <div class="container mx-auto max-w-xl">

            <!-- Page Header -->
            <div class="text-center mb-8">
                <h1 class="text-3xl md:text-4xl font-bold bg-gradient-to-r from-purple-600 to-pink-600 bg-clip-text text-transparent mb-3">
                    Register Your Salon
                </h1>
                <p class="text-gray-600">Create your salon account and start accepting bookings</p>
            </div>

            <!-- Auth Tabs -->
            <div class="bg-white rounded-2xl shadow-xl border border-gray-100 overflow-hidden">
                <!-- Tab Switcher -->
                <div class="flex border-b border-gray-200">
                    <button onclick="showTab('signin')" id="tab-signin"
                        class="flex-1 py-4 text-sm font-semibold text-gray-500 hover:text-purple-600 transition-colors border-b-2 border-transparent tab-btn">
                        Sign In
                    </button>
                    <button onclick="showTab('signup')" id="tab-signup"
                        class="flex-1 py-4 text-sm font-semibold text-purple-600 transition-colors border-b-2 border-purple-600 tab-btn">
                        Create Account
                    </button>
                </div>

                <!-- Sign In Form -->
                <div id="panel-signin" class="hidden p-8">
                    <div id="signin-error" class="hidden mb-4 p-3 bg-red-50 border border-red-200 rounded-lg text-red-700 text-sm"></div>
                    <form id="signin-form" class="space-y-4">
                        <div>
                            <label class="text-sm font-medium text-gray-700 mb-1.5 block">Email Address</label>
                            <div class="relative">
                                <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                                </svg>
                                <input type="email" id="signin-email" placeholder="you@example.com" required
                                    class="w-full h-11 pl-10 pr-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-purple-500" />
                            </div>
                        </div>
                        <div>
                            <label class="text-sm font-medium text-gray-700 mb-1.5 block">Password</label>
                            <div class="relative">
                                <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                                </svg>
                                <input type="password" id="signin-password" placeholder="Enter password" required
                                    class="w-full h-11 pl-10 pr-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-purple-500" />
                            </div>
                        </div>
                        <button type="submit" id="signin-btn"
                            class="w-full h-11 bg-gradient-to-r from-purple-600 to-pink-600 hover:from-purple-700 hover:to-pink-700 text-white font-semibold rounded-lg transition-all disabled:opacity-60">
                            Sign In to Salon Account
                        </button>
                    </form>
                </div>

                <!-- Sign Up Form -->
                <div id="panel-signup" class="p-8">
                    <div id="signup-error" class="hidden mb-4 p-3 bg-red-50 border border-red-200 rounded-lg text-red-700 text-sm"></div>
                    <form id="signup-form" class="space-y-4">
                        <div>
                            <label class="text-sm font-medium text-gray-700 mb-1.5 block">Full Name *</label>
                            <div class="relative">
                                <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                                </svg>
                                <input type="text" id="full-name" placeholder="Jane Doe" required
                                    class="w-full h-11 pl-10 pr-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-purple-500" />
                            </div>
                        </div>
                        <div>
                            <label class="text-sm font-medium text-gray-700 mb-1.5 block">Salon Name *</label>
                            <div class="relative">
                                <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
                                </svg>
                                <input type="text" id="salon-name" placeholder="e.g. Bella Beauty Studio" required
                                    class="w-full h-11 pl-10 pr-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-purple-500" />
                            </div>
                        </div>
                        <div>
                            <label class="text-sm font-medium text-gray-700 mb-1.5 block">Salon Location</label>
                            <div class="relative">
                                <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                                </svg>
                                <input type="text" id="salon-location" placeholder="e.g. Dubai, UAE"
                                    class="w-full h-11 pl-10 pr-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-purple-500" />
                            </div>
                        </div>
                        <div>
                            <label class="text-sm font-medium text-gray-700 mb-1.5 block">Email Address *</label>
                            <div class="relative">
                                <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                                </svg>
                                <input type="email" id="signup-email" placeholder="you@example.com" required
                                    class="w-full h-11 pl-10 pr-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-purple-500" />
                            </div>
                        </div>
                        <div>
                            <label class="text-sm font-medium text-gray-700 mb-1.5 block">Phone Number</label>
                            <div class="relative">
                                <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                                </svg>
                                <input type="tel" id="phone" placeholder="+971 50 123 4567"
                                    class="w-full h-11 pl-10 pr-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-purple-500" />
                            </div>
                        </div>
                        <div>
                            <label class="text-sm font-medium text-gray-700 mb-1.5 block">Password *</label>
                            <div class="relative">
                                <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                                </svg>
                                <input type="password" id="signup-password" placeholder="Min. 8 characters" required
                                    class="w-full h-11 pl-10 pr-10 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-purple-500" />
                                <button type="button" onclick="togglePw('signup-password', this)" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                                    </svg>
                                </button>
                            </div>
                        </div>
                        <div>
                            <label class="text-sm font-medium text-gray-700 mb-1.5 block">Confirm Password *</label>
                            <div class="relative">
                                <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                                </svg>
                                <input type="password" id="confirm-password" placeholder="Repeat password" required
                                    class="w-full h-11 pl-10 pr-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-purple-500" />
                            </div>
                        </div>
                        <div class="flex items-start gap-2">
                            <input type="checkbox" id="agree-terms" class="mt-0.5 rounded border-gray-300 text-purple-600" />
                            <label for="agree-terms" class="text-sm text-gray-600">
                                I agree to the <a href="#" class="text-purple-600 hover:underline">Terms of Service</a> and <a href="#" class="text-purple-600 hover:underline">Privacy Policy</a>
                            </label>
                        </div>
                        <button type="submit" id="signup-btn"
                            class="w-full h-11 bg-gradient-to-r from-purple-600 to-pink-600 hover:from-purple-700 hover:to-pink-700 text-white font-semibold rounded-lg transition-all disabled:opacity-60">
                            Create Salon Account
                        </button>
                    </form>
                </div>
            </div>

            <!-- Already have account link -->
            <p class="text-center mt-6 text-sm text-gray-600">
                Looking to book as a client?
                <a href="/auth" class="text-purple-600 hover:underline font-medium">Client Sign In</a>
            </p>
        </div>
    </div>

<script>
function showTab(tab) {
    const tabs = ['signin', 'signup'];
    tabs.forEach(t => {
        document.getElementById('panel-' + t).classList.toggle('hidden', t !== tab);
        const btn = document.getElementById('tab-' + t);
        if (t === tab) {
            btn.classList.add('text-purple-600', 'border-purple-600', 'border-b-2');
            btn.classList.remove('text-gray-500', 'border-transparent');
        } else {
            btn.classList.remove('text-purple-600', 'border-purple-600', 'border-b-2');
            btn.classList.add('text-gray-500', 'border-transparent');
        }
    });
}

function togglePw(inputId, btn) {
    const input = document.getElementById(inputId);
    input.type = input.type === 'password' ? 'text' : 'password';
}

// Check URL for mode
const urlParams = new URLSearchParams(window.location.search);
const mode = urlParams.get('mode');
if (mode === 'signin') showTab('signin');

document.getElementById('signin-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    const btn = document.getElementById('signin-btn');
    const errorEl = document.getElementById('signin-error');
    btn.disabled = true;
    btn.textContent = 'Signing in...';
    errorEl.classList.add('hidden');

    try {
        const resp = await fetch('/auth/login', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                email: document.getElementById('signin-email').value,
                password: document.getElementById('signin-password').value,
                role: 'owner'
            })
        });
        const data = await resp.json();
        if (resp.ok && data.token) {
            localStorage.setItem('auth_token', data.token);
            localStorage.setItem('user_data', JSON.stringify(data.user || {}));
            window.location.href = '/dashboard';
        } else {
            errorEl.textContent = data.message || 'Invalid credentials. Please try again.';
            errorEl.classList.remove('hidden');
        }
    } catch {
        errorEl.textContent = 'Network error. Please try again.';
        errorEl.classList.remove('hidden');
    } finally {
        btn.disabled = false;
        btn.textContent = 'Sign In to Salon Account';
    }
});

document.getElementById('signup-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    const btn = document.getElementById('signup-btn');
    const errorEl = document.getElementById('signup-error');

    const password = document.getElementById('signup-password').value;
    const confirm = document.getElementById('confirm-password').value;
    const terms = document.getElementById('agree-terms').checked;

    if (password !== confirm) {
        errorEl.textContent = 'Passwords do not match';
        errorEl.classList.remove('hidden');
        return;
    }
    if (password.length < 8) {
        errorEl.textContent = 'Password must be at least 8 characters';
        errorEl.classList.remove('hidden');
        return;
    }
    if (!terms) {
        errorEl.textContent = 'Please agree to the Terms of Service';
        errorEl.classList.remove('hidden');
        return;
    }

    btn.disabled = true;
    btn.textContent = 'Creating account...';
    errorEl.classList.add('hidden');

    try {
        const resp = await fetch('/auth/register', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                email: document.getElementById('signup-email').value,
                password: password,
                fullName: document.getElementById('full-name').value,
                phone: document.getElementById('phone').value,
                role: 'owner',
                salonName: document.getElementById('salon-name').value,
                salonLocation: document.getElementById('salon-location').value
            })
        });
        const data = await resp.json();
        if (resp.ok && data.token) {
            localStorage.setItem('auth_token', data.token);
            localStorage.setItem('user_data', JSON.stringify(data.user || {}));
            window.location.href = '/dashboard';
        } else {
            errorEl.textContent = data.message || 'Registration failed. Please try again.';
            errorEl.classList.remove('hidden');
        }
    } catch {
        errorEl.textContent = 'Network error. Please try again.';
        errorEl.classList.remove('hidden');
    } finally {
        btn.disabled = false;
        btn.textContent = 'Create Salon Account';
    }
});
</script>
</body>
</html>


