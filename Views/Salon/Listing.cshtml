@{
    Layout = null;
    ViewData["Title"] = "Find a Salon";
    ViewData["Description"] = "Discover top beauty salons near you and book an appointment.";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Katia Beauty Platform</title>
    <meta name="description" content="@ViewData["Description"]" />
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen bg-white">

    <!-- Header -->
    <header class="bg-white/80 backdrop-blur-md border-b border-purple-100 sticky top-0 z-50">
        <div class="container mx-auto px-4 py-4 flex items-center justify-between max-w-7xl">
            <a href="/" class="flex items-center gap-2">
                <div class="w-8 h-8 bg-gradient-to-r from-purple-600 to-pink-600 rounded-lg flex items-center justify-center">
                    <span class="text-white font-bold text-sm">K</span>
                </div>
                <span class="font-bold text-xl bg-gradient-to-r from-purple-600 to-pink-600 bg-clip-text text-transparent">Katia</span>
            </a>
            <nav class="hidden md:flex items-center gap-6">
                <a href="/" class="text-gray-600 hover:text-purple-600 transition-colors text-sm font-medium">Home</a>
                <a href="/pricing" class="text-gray-600 hover:text-purple-600 transition-colors text-sm font-medium">Pricing</a>
                <a href="/feed" class="text-gray-600 hover:text-purple-600 transition-colors text-sm font-medium">Feed</a>
                <a href="/auth" class="bg-gradient-to-r from-purple-600 to-pink-600 text-white px-4 py-2 rounded-lg text-sm font-medium hover:opacity-90 transition-opacity">Sign In</a>
            </nav>
        </div>
    </header>

    <div class="container mx-auto px-4 py-4 md:py-8 max-w-7xl">

        <!-- Back Button -->
        <a href="/" class="flex items-center gap-2 text-gray-600 hover:text-purple-600 mb-4 md:mb-6 transition-colors w-fit">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
            </svg>
            <span class="font-medium">Back to Home</span>
        </a>

        <div class="mb-4 md:mb-8">
            <h1 class="text-2xl md:text-4xl font-bold text-gray-900 mb-2">Beauty Salons Near You</h1>
            <p class="text-gray-600" id="results-count">Searching salons...</p>
        </div>

        <!-- Mobile Filter Bar -->
        <div class="md:hidden flex items-center gap-2 mb-4">
            <button id="mobile-filter-btn" class="flex-1 flex items-center justify-center gap-2 border border-gray-300 rounded-lg py-2 px-4 text-sm font-medium text-gray-700 hover:border-purple-400 hover:text-purple-600">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"/>
                </svg>
                Filters
            </button>
            <select id="mobile-sort" class="flex-1 border border-gray-300 rounded-lg py-2 px-4 text-sm font-medium text-gray-700 focus:outline-none focus:ring-2 focus:ring-purple-500">
                <option value="recommended">Recommended</option>
                <option value="rating">Highest Rating</option>
                <option value="distance">Nearest</option>
                <option value="new">Newest</option>
            </select>
        </div>

        <div class="flex gap-8">
            <!-- Filters Sidebar -->
            <aside id="filters-sidebar" class="hidden md:block w-80 flex-shrink-0">
                <div class="p-6 border border-gray-200 rounded-xl sticky top-24 bg-white shadow-sm">
                    <div class="flex items-center justify-between mb-6">
                        <h2 class="text-xl font-bold">Filters</h2>
                        <button id="clear-filters" class="text-sm text-gray-500 hover:text-purple-600 font-medium">Clear all</button>
                    </div>

                    <!-- Service Category -->
                    <div class="mb-6">
                        <h3 class="font-semibold mb-3">Service Category</h3>
                        <div class="space-y-3" id="category-filters">
                            @{
                                var categories = new[] { "Hair", "Nails", "Makeup", "Skincare", "Massage", "Eyebrows & Lashes", "Waxing", "Spa" };
                            }
                            @foreach (var cat in categories)
                            {
                                <div class="flex items-center space-x-2">
                                    <input type="checkbox" id="cat-@cat.ToLower().Replace(" ", "-").Replace("&", "and")" class="category-checkbox rounded border-gray-300 text-purple-600 focus:ring-purple-500" value="@cat" />
                                    <label for="cat-@cat.ToLower().Replace(" ", "-").Replace("&", "and")" class="text-sm font-normal cursor-pointer text-gray-700">@cat</label>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Minimum Rating -->
                    <div class="mb-6">
                        <h3 class="font-semibold mb-3">Minimum Rating</h3>
                        <div class="space-y-2">
                            @foreach (var r in new[] { "4.5", "4.0", "3.5", "3.0" })
                            {
                                <div class="flex items-center space-x-2">
                                    <input type="radio" name="min-rating" id="rating-@r.Replace(".", "")" value="@r" class="border-gray-300 text-purple-600 focus:ring-purple-500" />
                                    <label for="rating-@r.Replace(".", "")" class="text-sm font-normal cursor-pointer text-gray-700">@r+ stars</label>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Availability -->
                    <div class="mb-6">
                        <h3 class="font-semibold mb-3">Availability</h3>
                        <div class="flex items-center space-x-2">
                            <input type="checkbox" id="available-today" class="rounded border-gray-300 text-purple-600 focus:ring-purple-500" />
                            <label for="available-today" class="text-sm font-normal cursor-pointer text-gray-700">Available Today</label>
                        </div>
                    </div>

                    <!-- Distance -->
                    <div>
                        <h3 class="font-semibold mb-3">Distance</h3>
                        <select id="max-distance" class="w-full border border-gray-300 rounded-md py-2 px-3 text-sm focus:outline-none focus:ring-2 focus:ring-purple-500">
                            <option value="1">Within 1 km</option>
                            <option value="3">Within 3 km</option>
                            <option value="5" selected>Within 5 km</option>
                            <option value="10">Within 10 km</option>
                        </select>
                    </div>
                </div>
            </aside>

            <!-- Results -->
            <div class="flex-1">
                <!-- Desktop Sort -->
                <div class="hidden md:flex items-center justify-end mb-6">
                    <span class="text-sm text-gray-600 mr-3">Sort by:</span>
                    <select id="desktop-sort" class="border border-gray-300 rounded-md py-2 px-3 text-sm w-48 focus:outline-none focus:ring-2 focus:ring-purple-500">
                        <option value="recommended">Recommended</option>
                        <option value="rating">Highest Rating</option>
                        <option value="distance">Nearest</option>
                        <option value="new">Newest</option>
                    </select>
                </div>

                <!-- Salons Grid -->
                <div id="salons-grid" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4 md:gap-6 pb-20 md:pb-0">
                    <!-- Loading skeletons -->
                    @for (int i = 0; i < 6; i++)
                    {
                        <div class="border border-gray-200 rounded-xl overflow-hidden animate-pulse">
                            <div class="w-full h-48 bg-gray-200"></div>
                            <div class="p-4">
                                <div class="h-4 bg-gray-200 rounded w-3/4 mb-2"></div>
                                <div class="h-3 bg-gray-200 rounded w-1/2 mb-3"></div>
                                <div class="h-3 bg-gray-200 rounded w-full"></div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Empty State -->
                <div id="empty-state" class="hidden text-center py-16">
                    <p class="text-gray-500 text-lg mb-4">No salons found matching your criteria</p>
                    <button id="clear-filters-empty" class="border border-gray-300 rounded-lg py-2 px-6 text-sm font-medium text-gray-700 hover:border-purple-400 hover:text-purple-600 transition-colors">
                        Clear all filters
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer class="bg-gray-900 text-gray-400 py-12 mt-16">
        <div class="container mx-auto px-4 max-w-6xl">
            <div class="flex flex-col md:flex-row items-center justify-between gap-4">
                <div class="flex items-center gap-2">
                    <div class="w-8 h-8 bg-gradient-to-r from-purple-600 to-pink-600 rounded-lg flex items-center justify-center">
                        <span class="text-white font-bold text-sm">K</span>
                    </div>
                    <span class="text-white font-bold text-lg">Katia</span>
                </div>
                <p class="text-sm">&copy; 2024 Katia Beauty Platform. All rights reserved.</p>
                <div class="flex gap-4 text-sm">
                    <a href="/pricing" class="hover:text-white transition-colors">Pricing</a>
                    <a href="/contact" class="hover:text-white transition-colors">Contact</a>
                </div>
            </div>
        </div>
    </footer>

<script>
const grid = document.getElementById('salons-grid');
const emptyState = document.getElementById('empty-state');
const resultsCount = document.getElementById('results-count');

let allSalons = [];

async function loadSalons() {
    try {
        const resp = await fetch('/api/salons');
        if (resp.ok) {
            const data = await resp.json();
            allSalons = data.salons || data || [];
        }
    } catch (e) {
        allSalons = [];
    }
    renderSalons(allSalons);
}

function renderSalons(salons) {
    if (!salons.length) {
        grid.innerHTML = '';
        emptyState.classList.remove('hidden');
        resultsCount.textContent = '0 salons found';
        return;
    }
    emptyState.classList.add('hidden');
    resultsCount.textContent = salons.length + ' salon' + (salons.length !== 1 ? 's' : '') + ' found';
    grid.innerHTML = salons.map(salon => `
        <a href="/salon/profile/${salon.id}" class="block border border-gray-200 rounded-xl overflow-hidden hover:shadow-lg transition-shadow group">
            <div class="relative w-full h-48 bg-gradient-to-br from-purple-100 to-pink-100 overflow-hidden">
                ${salon.imageUrl
                    ? `<img src="${salon.imageUrl}" alt="${salon.name}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />`
                    : `<div class="w-full h-full flex items-center justify-center"><span class="text-6xl">✂️</span></div>`
                }
                ${salon.isOpenNow ? `<span class="absolute top-3 left-3 bg-green-500 text-white text-xs font-bold px-2 py-1 rounded-full">Open Now</span>` : ''}
            </div>
            <div class="p-4">
                <h3 class="font-bold text-gray-900 text-lg mb-1 truncate">${salon.name}</h3>
                <div class="flex items-center gap-1 mb-2">
                    <svg class="w-4 h-4 text-yellow-400 fill-current" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    <span class="text-sm font-semibold text-gray-900">${(salon.rating || 4.5).toFixed(1)}</span>
                    <span class="text-sm text-gray-500">(${salon.reviewCount || 0} reviews)</span>
                </div>
                <p class="text-sm text-gray-500 truncate">
                    <svg class="w-3.5 h-3.5 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    ${salon.address || salon.city || 'Location unavailable'}
                </p>
            </div>
        </a>
    `).join('');
}

document.getElementById('desktop-sort')?.addEventListener('change', function() {
    const val = this.value;
    let sorted = [...allSalons];
    if (val === 'rating') sorted.sort((a, b) => (b.rating || 0) - (a.rating || 0));
    renderSalons(sorted);
});

document.getElementById('clear-filters')?.addEventListener('click', function() {
    document.querySelectorAll('.category-checkbox').forEach(cb => cb.checked = false);
    document.querySelectorAll('input[name="min-rating"]').forEach(r => r.checked = false);
    document.getElementById('available-today').checked = false;
    renderSalons(allSalons);
});

document.getElementById('clear-filters-empty')?.addEventListener('click', function() {
    document.getElementById('clear-filters').click();
});

loadSalons();
</script>
</body>
</html>


