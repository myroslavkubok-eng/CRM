<script src="https://cdn.tailwindcss.com"></script>

@section Scripts {
<script>
const basePrices = { basic: 99, standard: 299, business: 499 };
const discounts = { monthly: {}, 'semi-annual': { basic:15, standard:15, business:20 }, annual: { basic:20, standard:25, business:30 } };
let currentBilling = 'monthly';

function setBilling(period) {
    currentBilling = period;
    const buttons = ['monthly','semi-annual','annual'];
    buttons.forEach(b => {
        const btn = document.getElementById('btn-' + b);
        btn.className = btn.className.replace(/bg-\S+ text-white shadow-md/g, '').replace(/text-gray-700/g, '').trim();
    });
    const active = document.getElementById('btn-' + period);
    if (period === 'monthly') active.classList.add('bg-gray-900','text-white','shadow-md');
    else if (period === 'semi-annual') active.classList.add('bg-gradient-to-r','from-blue-600','to-cyan-600','text-white','shadow-md');
    else active.classList.add('bg-gradient-to-r','from-green-600','to-emerald-600','text-white','shadow-md');

    ['basic','standard','business'].forEach(plan => {
        const base = basePrices[plan];
        let price, suffix, savings = '';
        if (period === 'monthly') {
            price = base; suffix = '/mo';
        } else {
            const months = period === 'semi-annual' ? 6 : 12;
            const disc = discounts[period][plan];
            price = Math.round(base * months * (1 - disc/100));
            suffix = period === 'semi-annual' ? '/6mo' : '/yr';
            const saved = Math.round(base * months * disc / 100);
            savings = '💚 Save AED ' + saved;
        }
        document.getElementById('price-' + plan).textContent = 'AED ' + price;
        document.getElementById('period-' + plan).textContent = suffix;
        const savingsEl = document.getElementById('savings-' + plan);
        if (savings) { savingsEl.textContent = savings; savingsEl.classList.remove('hidden'); }
        else savingsEl.classList.add('hidden');
    });
}
</script>
}
